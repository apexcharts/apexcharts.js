      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"line\"\n        height=\"350\"\n        width=\"600\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'North',\n          data: [\n            {\n              x: 'Q1',\n              y: 503,\n            },\n            {\n              x: 'Q2',\n              y: 580,\n            },\n            {\n              x: 'Q3',\n              y: 135,\n            },\n          ],\n        },\n        {\n          name: 'South',\n          data: [\n            {\n              x: 'Q1',\n              y: 733,\n            },\n            {\n              x: 'Q2',\n              y: 385,\n            },\n            {\n              x: 'Q3',\n              y: 715,\n            },\n          ],\n        },\n        {\n          name: 'East',\n          data: [\n            {\n              x: 'Q1',\n              y: 255,\n            },\n            {\n              x: 'Q2',\n              y: 211,\n            },\n            {\n              x: 'Q3',\n              y: 441,\n            },\n          ],\n        },\n        {\n          name: 'West',\n          data: [\n            {\n              x: 'Q1',\n              y: 428,\n            },\n            {\n              x: 'Q2',\n              y: 749,\n            },\n            {\n              x: 'Q3',\n              y: 559,\n            },\n          ],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          height: 350,\n          width: 600,\n          type: 'line',\n        },\n        plotOptions: {\n          line: {\n            isSlopeChart: true,\n          },\n        },\n        title: {\n          text: 'Regional Sales Rank by Quarter',\n        },\n        tooltip: {\n          followCursor: true,\n          intersect: false,\n          shared: true,\n        },\n        dataLabels: {\n          background: {\n            enabled: true,\n          },\n          formatter(val, opts) {\n            const seriesName = opts.w.config.series[opts.seriesIndex].name\n            return val !== null ? seriesName : ''\n          },\n        },\n        yaxis: {\n          show: true,\n          labels: {\n            show: true,\n          },\n        },\n        xaxis: {\n          position: 'bottom',\n        },\n        legend: {\n          show: true,\n          position: 'top',\n          horizontalAlign: 'left',\n        },\n        stroke: {\n          width: [2, 3, 4, 2],\n          dashArray: [0, 0, 5, 2],\n          curve: 'smooth',\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
