{
  "title": "High-Density Candlestick with the Canvas Renderer",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"panel\">\n      <div class=\"controls\">\n        <label>\n          Renderer:\n          <select id=\"rendererMode\">\n            <option value=\"canvas\" selected>canvas</option>\n            <option value=\"svg\">svg</option>\n            <option value=\"auto\">auto</option>\n          </select>\n        </label>\n        <label>\n          Candles:\n          <select id=\"candleCount\">\n            <option value=\"2000\">2,000</option>\n            <option value=\"10000\" selected>10,000</option>\n            <option value=\"50000\">50,000</option>\n            <option value=\"100000\">100,000</option>\n          </select>\n        </label>\n        <label>\n          <input type=\"checkbox\" id=\"lttbToggle\" checked />\n          Enable LTTB downsampling\n        </label>\n        <button id=\"rerender\">Re-render</button>\n        <button id=\"resetZoom\">Reset zoom</button>\n      </div>\n\n      <div class=\"stats\" id=\"stats\"></div>\n\n      <div class=\"note\">\n        The candle bodies and wicks are painted into a single\n        <code>&lt;canvas&gt;</code>\n        while the axes, grid, crosshair, zoom selection, and the OHLC tooltip\n        stay as SVG. Hover to read Open/High/Low/Close, and drag to zoom,\n        exactly as in SVG mode: the y-axis auto-scales to the visible price\n        range on every zoom (via\n        <code>zoom.autoScaleYaxis: true</code>). Note that with\n        <b>renderer: 'auto'</b> candlesticks only promote to canvas at 50,000\n        candles (they have no per-point markers or data labels for the threshold\n        to count), so this demo selects <b>canvas</b> explicitly. Switch to\n        <b>svg</b> at 50,000+ candles to feel the difference. <br /><br />\n        <b>Enable LTTB downsampling</b> turns on\n        <code>chart.dataReducer</code> with a threshold of 11,000 points, so the\n        2,000 and 10,000 counts always render raw while 50,000 and 100,000\n        aggregate to a tenth of their size (5,000 and 10,000 on-screen candles).\n        Each bucket keeps its opening open, highest high, lowest low and final\n        close, and every zoom re-samples just the visible window, so full\n        per-candle detail returns as you zoom in. Uncheck it to compare raw\n        rendering at every size: the stats line shows how many candles are\n        actually drawn.\n      </div>\n    </div>\n\n    <div id=\"chart\"></div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\nvar candleCount = 10000\n\n// OHLC random walk: each candle opens at the previous close so the series\n// reads as a continuous price, dense enough that individual candles blur into\n// a band (which is exactly where the canvas renderer earns its keep).\n//\n// The PRNG reseeds on every call (same LCG and seed as the template's global\n// Math.random override, so the initial render is unchanged). The template\n// override alone is not enough here: its seed is a running stream, so the\n// second generateCandles call, e.g. after toggling a control, would continue\n// the stream and produce a different walk, which read as \"the data changed\"\n// when comparing downsampling on/off.\nfunction generateCandles(count) {\n  var seed = 42\n  function rnd() {\n    seed = (seed * 16807) % 2147483647\n    return (seed - 1) / 2147483646\n  }\n  var data = new Array(count)\n  var t = new Date('2015-01-01T00:00:00Z').getTime()\n  var step = 60 * 60 * 1000 // 1 hour\n  var o = 100\n  for (var i = 0; i < count; i++) {\n    var h = o + rnd() * 6\n    var l = o - rnd() * 6\n    var c = l + rnd() * (h - l)\n    data[i] = {\n      x: t + i * step,\n      y: [+o.toFixed(2), +h.toFixed(2), +l.toFixed(2), +c.toFixed(2)],\n    }\n    // reflect off a floor so the walk never drifts into negative prices\n    o = c < 20 ? 40 - c : c\n  }\n  return data\n}\n\nvar candleData = generateCandles(candleCount)\n\n// Stateless helper shared by the vanilla, React and Vue builds. The chart-bound\n// updateStats (and its lastRenderMs) live in each per-format script instead,\n// since they read the live instance and per-render timing.\nfunction domNodeCount() {\n  var el = document.querySelector('#chart')\n  return el ? el.getElementsByTagName('*').length : 0\n}\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [{ name: 'Price', data: candleData }],\nchartOptions: {\nchart: {\n  height: 480,\n  type: 'candlestick',\n  renderer: 'canvas',\n  rendererThreshold: 8000,\n  // Above 11,000 points the raw series is aggregated to a tenth of its size\n  // (each bucket keeps its open, max high, min low and last close), and every\n  // zoom re-samples the visible window, so detail returns as you zoom in. The\n  // 2,000 and 10,000 counts stay under the threshold and render raw.\n  // rebuild() recomputes targetPoints as candleCount / 10 on every change.\n  dataReducer: { enabled: true, threshold: 11000, targetPoints: 1000 },\n  animations: { enabled: true },\n  zoom: { enabled: true, type: 'x', autoScaleYaxis: true },\n  toolbar: { autoSelected: 'zoom' },\n},\ntitle: {\n  text: 'Candlestick: 10,000 candles on the canvas renderer',\n  align: 'left',\n},\nsubtitle: {\n  text: 'Bodies and wicks paint to a canvas layer; axes, crosshair, zoom and the OHLC tooltip stay SVG',\n  align: 'left',\n},\nxaxis: {\n  type: 'datetime',\n  labels: { datetimeUTC: false },\n},\nyaxis: {\n  tooltip: { enabled: true },\n  labels: {\n    formatter: function (val) {\n      return val.toFixed(0)\n    },\n  },\n},\n},\ncandleChart: null,\ncandleDisposed: false,\n}\n},\nmounted: function () {\n  // This demo destroys and recreates the chart instance on every control change,\n  // so it skips the vue-apexcharts wrapper and creates the instance in #chart\n  // directly, exactly like the vanilla build. candleCount, candleData,\n  // generateCandles and domNodeCount live in the shared head script.\n  var me = this\n  var lastRenderMs = 0\n  var chart = null\n\n  // The vanilla build gets a mutable `options` global from the template; rebuild\n  // it here from the parsed chart state (copy the sub-objects we mutate so the\n  // component data is left untouched).\n  var options = Object.assign({ series: me.series }, me.chartOptions)\n  options.chart = Object.assign({}, me.chartOptions.chart)\n  options.title = Object.assign({}, me.chartOptions.title)\n\n  function updateStats() {\n    var el = document.getElementById('stats')\n    if (!el || !chart) return\n    var active = chart.getActiveRenderer ? chart.getActiveRenderer() : 'svg'\n    var drawn =\n      chart.w && chart.w.seriesData && chart.w.seriesData.series[0]\n        ? chart.w.seriesData.series[0].length\n        : 0\n    el.innerHTML =\n      'Candles: <b>' +\n      candleCount.toLocaleString() +\n      '</b> &nbsp;·&nbsp; Drawn: <b>' +\n      drawn.toLocaleString() +\n      '</b> &nbsp;·&nbsp; Active renderer: <b>' +\n      active.toUpperCase() +\n      '</b> &nbsp;·&nbsp; DOM nodes in chart: <b>' +\n      domNodeCount().toLocaleString() +\n      '</b> &nbsp;·&nbsp; Render: <b>' +\n      (lastRenderMs > 0 ? lastRenderMs + ' ms' : 'change a control to time it') +\n      '</b>'\n  }\n\n  function rebuild() {\n    candleCount = parseInt(document.getElementById('candleCount').value, 10)\n    var mode = document.getElementById('rendererMode').value\n    var lttbOn = document.getElementById('lttbToggle').checked\n\n    candleData = generateCandles(candleCount)\n    options.chart.renderer = mode\n    options.chart.dataReducer = {\n      enabled: lttbOn,\n      threshold: 11000,\n      // keep a tenth of the raw candles: 50k draws 5,000, 100k draws 10,000\n      targetPoints: Math.round(candleCount / 10),\n    }\n    options.series = [{ name: 'Price', data: candleData }]\n    options.title.text =\n      'Candlestick: ' +\n      candleCount.toLocaleString() +\n      ' candles on the ' +\n      (mode === 'auto' ? 'auto-selected' : mode) +\n      ' renderer'\n\n    var t = performance.now()\n    if (chart) chart.destroy()\n    chart = new ApexCharts(document.querySelector('#chart'), options)\n    me.candleChart = chart\n    chart.render().then(function () {\n      if (me.candleDisposed) return\n      lastRenderMs = Math.round(performance.now() - t)\n      updateStats()\n    })\n  }\n\n  document.getElementById('rerender').addEventListener('click', rebuild)\n  document.getElementById('rendererMode').addEventListener('change', rebuild)\n  document.getElementById('candleCount').addEventListener('change', rebuild)\n  document.getElementById('lttbToggle').addEventListener('change', rebuild)\n  document.getElementById('resetZoom').addEventListener('click', function () {\n    if (chart) chart.resetSeries(true, true)\n  })\n\n  // Initial render into #chart, then fill in the live metrics.\n  chart = new ApexCharts(document.querySelector('#chart'), options)\n  me.candleChart = chart\n  chart.render().then(function () {\n    if (me.candleDisposed) return\n    updateStats()\n  })\n},\nbeforeDestroy: function () {\n  this.candleDisposed = true\n  if (this.candleChart) this.candleChart.destroy()\n},,\n}\n</script>\n\n<style>\n#chart {\n  max-width: 1000px;\n  margin: 20px auto;\n}\n.panel {\n  max-width: 1000px;\n  margin: 16px auto;\n  font-family: sans-serif;\n}\n.controls {\n  display: flex;\n  gap: 14px;\n  align-items: center;\n  flex-wrap: wrap;\n  margin-bottom: 8px;\n}\n.controls label {\n  font-size: 14px;\n}\n.controls select {\n  padding: 4px 6px;\n  font-size: 14px;\n}\n.controls button {\n  padding: 6px 14px;\n  cursor: pointer;\n}\n.stats {\n  font-family: monospace;\n  font-size: 13px;\n  color: #555;\n  line-height: 1.6;\n}\n.stats b {\n  color: #111;\n}\n.note {\n  background: #f4f8ff;\n  border-left: 3px solid #5b8cff;\n  padding: 10px 14px;\n  font-size: 13px;\n  color: #234;\n  margin-top: 10px;\n  border-radius: 2px;\n}\n.note code {\n  background: #e6eeff;\n  padding: 1px 5px;\n  border-radius: 3px;\n}\n</style>\n"
    }
  ]
}