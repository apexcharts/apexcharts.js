{
  "title": "CandleStick Chart - Large Dataset (Data Reducer)",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"candlestick\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\n// Deterministic OHLC generator (no Math.random, so snapshots stay stable\n// across runs). 2000 daily candles — far more than can be visually resolved in\n// the chart's width, so chart.dataReducer downsamples them with OHLC-aware\n// bucket aggregation (open=first, high=max, low=min, close=last) down to\n// ~targetPoints. The reducer is zoom-aware: it re-slices the raw series to the\n// visible x-window on each zoom and re-aggregates, so zooming in progressively\n// reveals more detail while every frame stays cheap to render. See\n// Data.parseDataAxisCharts (the dataReducer block) + Data.ohlcAggregate.\nwindow.generateCandles = function (count) {\n  var data = []\n  var base = new Date(2015, 0, 1).getTime()\n  var day = 86400000\n  var last = 100\n  for (var i = 0; i < count; i++) {\n    // Pseudo-random in [0,1) from a hashed sine — deterministic per index.\n    var noise = Math.sin(i * 12.9898) * 43758.5453\n    noise = noise - Math.floor(noise)\n    // Mean-reverting random walk (pulls gently back toward 100) so the series\n    // looks like an organic price, not a periodic wave.\n    var move = (noise - 0.5) * 6 + (100 - last) * 0.02\n    var open = last\n    var close = Math.round((open + move) * 100) / 100\n    var high = Math.round((Math.max(open, close) + noise * 3) * 100) / 100\n    var low = Math.round((Math.min(open, close) - noise * 3) * 100) / 100\n    data.push({ x: base + i * day, y: [open, high, low, close] })\n    last = close\n  }\n  return data\n}\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          data: generateCandles(2000),\n        },\n      ],\n      chartOptions: {\n        chart: {\n          type: 'candlestick',\n          height: 350,\n          // Zoom-aware OHLC downsampling. The raw 2000 candles can't be resolved at the\n          // chart's pixel width, so they're bucket-aggregated down to ~targetPoints for\n          // a cheap render; zooming re-slices the raw data to the visible window and\n          // re-aggregates, so detail increases as you zoom in (once the window holds\n          // fewer than targetPoints candles, every raw candle is shown).\n          dataReducer: {\n            enabled: true,\n            targetPoints: 250,\n          },\n          zoom: {\n            // Rescale the y-axis to the high/low range of the candles inside the\n            // zoomed x-window. Range.js already narrows the y-scan to the visible\n            // window for candlesticks; this flag (off by default library-wide) opts\n            // this large-dataset demo into the stock-chart-style autoscale on zoom.\n            autoScaleYaxis: true,\n          },\n        },\n        title: {\n          text: 'Large Dataset (2000 candles) — Data Reducer',\n          align: 'left',\n        },\n        xaxis: {\n          type: 'datetime',\n        },\n        yaxis: {\n          tooltip: {\n            enabled: true,\n          },\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
}