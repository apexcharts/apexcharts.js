      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"radar\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Revenue ($k)',\n          data: [80, 50, 30, 40, 100, 20],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          height: 350,\n          type: 'radar',\n        },\n        title: {\n          text: 'Monthly Sales Performance',\n        },\n        yaxis: {\n          stepSize: 20,\n        },\n        xaxis: {\n          categories: ['January', 'February', 'March', 'April', 'May', 'June'],\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 450px;\n  margin: 35px auto;\n}\n</style>\n"
    }
