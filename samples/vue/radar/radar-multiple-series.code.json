{
  "title": "Basic Radar",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"radar\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Model X',\n          data: [92, 60, 88, 95, 55, 90],\n        },\n        {\n          name: 'Model Y',\n          data: [70, 95, 66, 78, 85, 72],\n        },\n        {\n          name: 'Model Z',\n          data: [80, 78, 82, 70, 68, 60],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          height: 350,\n          type: 'radar',\n        },\n        title: {\n          text: 'Smartphone Comparison',\n        },\n        stroke: {\n          width: 2,\n        },\n        fill: {\n          opacity: 0.1,\n        },\n        markers: {\n          size: 0,\n        },\n        yaxis: {\n          stepSize: 20,\n        },\n        xaxis: {\n          categories: [\n            'Performance',\n            'Battery',\n            'Camera',\n            'Display',\n            'Value',\n            'Design',\n          ],\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 450px;\n  margin: 35px auto;\n}\n</style>\n"
    }
