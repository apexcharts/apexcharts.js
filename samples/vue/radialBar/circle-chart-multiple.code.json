{
  "title": "Circle Gauge Chart - Multiple",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"radialBar\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [68, 82, 54, 91],\n      chartOptions: {\n        chart: {\n          height: 350,\n          type: 'radialBar',\n        },\n        plotOptions: {\n          radialBar: {\n            dataLabels: {\n              name: {\n                fontSize: '22px',\n              },\n              value: {\n                fontSize: '16px',\n              },\n              total: {\n                show: true,\n                label: 'Average',\n                formatter: function (w) {\n                  // custom formatter: rounded average across all series, with a unit\n                  var total = w.globals.seriesTotals.reduce(function (a, b) {\n                    return a + b\n                  }, 0)\n                  return Math.round(total / w.globals.series.length) + '%'\n                },\n              },\n            },\n          },\n        },\n        labels: ['North', 'South', 'East', 'West'],\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  padding: 0;\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
}