      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"radialBar\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [72],\n      chartOptions: {\n        chart: {\n          height: 350,\n          type: 'radialBar',\n        },\n        plotOptions: {\n          radialBar: {\n            hollow: {\n              margin: 15,\n              size: '70%',\n              image: '../../assets/images/clock.png',\n              imageWidth: 64,\n              imageHeight: 64,\n              imageClipped: false,\n            },\n            dataLabels: {\n              name: {\n                show: false,\n                color: '#fff',\n              },\n              value: {\n                show: true,\n                color: '#333',\n                offsetY: 70,\n                fontSize: '22px',\n              },\n            },\n          },\n        },\n        colors: ['#20E647'],\n        fill: {\n          type: 'solid',\n        },\n        stroke: {\n          lineCap: 'round',\n        },\n        labels: ['Time on Task'],\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  padding: 0;\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
