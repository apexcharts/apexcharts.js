  "title": "Range Column Chart",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"rangeBar\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: '2024',\n          data: [\n            {\n              x: 'Jan',\n              y: [-2, 6],\n            },\n            {\n              x: 'Apr',\n              y: [8, 18],\n            },\n            {\n              x: 'Jul',\n              y: [18, 29],\n            },\n            {\n              x: 'Oct',\n              y: [7, 16],\n            },\n          ],\n        },\n        {\n          name: '2025',\n          data: [\n            {\n              x: 'Jan',\n              y: [0, 7],\n            },\n            {\n              x: 'Apr',\n              y: [9, 20],\n            },\n            {\n              x: 'Jul',\n              y: [19, 31],\n            },\n            {\n              x: 'Oct',\n              y: [8, 17],\n            },\n          ],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          type: 'rangeBar',\n          height: 350,\n        },\n        title: {\n          text: 'Monthly Temperature Range',\n          align: 'left',\n        },\n        plotOptions: {\n          bar: {\n            horizontal: false,\n          },\n        },\n        dataLabels: {\n          enabled: true,\n        },\n        stroke: {\n          width: 2,\n          colors: ['#fff'],\n        },\n        yaxis: {\n          labels: {\n            formatter: function (val) {\n              return val + '°C'\n            },\n          },\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
