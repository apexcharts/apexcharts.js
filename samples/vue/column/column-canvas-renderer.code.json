{
  "title": "High-Density Column Chart with the Canvas Renderer",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"panel\">\n      <div class=\"controls\">\n        <label>\n          Renderer:\n          <select id=\"rendererMode\">\n            <option value=\"canvas\" selected>canvas</option>\n            <option value=\"svg\">svg</option>\n            <option value=\"auto\">auto</option>\n          </select>\n        </label>\n        <label>\n          Bars:\n          <select id=\"barCount\">\n            <option value=\"2000\">2,000</option>\n            <option value=\"10000\" selected>10,000</option>\n            <option value=\"50000\">50,000</option>\n            <option value=\"100000\">100,000</option>\n          </select>\n        </label>\n        <button id=\"rerender\">Re-render</button>\n        <button id=\"resetZoom\">Reset zoom</button>\n      </div>\n\n      <div class=\"stats\" id=\"stats\"></div>\n\n      <div class=\"note\">\n        The bar bodies are painted into a single\n        <code>&lt;canvas&gt;</code> while the axes, grid, zoom, and shared\n        tooltip stay as SVG. Zooming auto-scales the y-axis to the visible bars\n        while keeping the 0 baseline (via\n        <code>zoom.autoScaleYaxis: true</code>), so the bars still read as\n        magnitude.\n        <b>Data labels stay SVG</b>\n        (the hybrid keeps chrome as SVG), so they are turned off here: 10,000\n        labels would be one DOM node each and unreadable at this density. With\n        that,\n        <b>renderer: 'auto'</b> promotes columns only at 50,000 bars, so this\n        demo selects <b>canvas</b> explicitly. Switch to <b>svg</b> at 50,000+\n        bars to feel the difference: one node per bar instead of a few dozen\n        total.\n      </div>\n    </div>\n\n    <div id=\"chart\"></div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\nvar barCount = 10000\n\n// Smooth-ish random heights so the dense column band has visible structure.\nfunction generateBars(count) {\n  var data = new Array(count)\n  var y = 60\n  for (var i = 0; i < count; i++) {\n    y += (Math.random() - 0.5) * 12\n    if (y < 10) y = 10\n    if (y > 100) y = 100\n    data[i] = { x: i, y: Math.round(y) }\n  }\n  return data\n}\n\nvar barData = generateBars(barCount)\n\n// Stateless helper shared by the vanilla, React and Vue builds. The chart-bound\n// updateStats (and its lastRenderMs) live in each per-format script instead,\n// since they read the live instance and per-render timing.\nfunction domNodeCount() {\n  var el = document.querySelector('#chart')\n  return el ? el.getElementsByTagName('*').length : 0\n}\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [{ name: 'Value', data: barData }],\nchartOptions: {\nchart: {\n  height: 480,\n  type: 'bar',\n  renderer: 'canvas',\n  rendererThreshold: 8000,\n  animations: { enabled: false },\n  zoom: { enabled: true, type: 'x', autoScaleYaxis: true },\n  toolbar: { autoSelected: 'zoom' },\n},\nplotOptions: {\n  bar: { columnWidth: '90%' },\n},\ndataLabels: { enabled: false },\ncolors: ['#008FFB'],\ntitle: {\n  text: 'Column chart: 10,000 bars on the canvas renderer',\n  align: 'left',\n},\nsubtitle: {\n  text: 'Bar bodies paint to a canvas layer; axes, grid, zoom and tooltip stay SVG (data labels off at this density)',\n  align: 'left',\n},\nxaxis: {\n  type: 'numeric',\n  tickAmount: 10,\n  labels: {\n    formatter: function (val) {\n      return parseFloat(val).toFixed(0)\n    },\n  },\n},\ntooltip: { shared: true, intersect: false },\n},\nbarChart: null,\nbarDisposed: false,\n}\n},\nmounted: function () {\n  // This demo destroys and recreates the chart instance on every control change,\n  // so it skips the vue-apexcharts wrapper and creates the instance in #chart\n  // directly, exactly like the vanilla build. barCount, barData, generateBars\n  // and domNodeCount live in the shared head script.\n  var me = this\n  var lastRenderMs = 0\n  var chart = null\n\n  // The vanilla build gets a mutable `options` global from the template; rebuild\n  // it here from the parsed chart state (copy the sub-objects we mutate so the\n  // component data is left untouched).\n  var options = Object.assign({ series: me.series }, me.chartOptions)\n  options.chart = Object.assign({}, me.chartOptions.chart)\n  options.title = Object.assign({}, me.chartOptions.title)\n\n  function updateStats() {\n    var el = document.getElementById('stats')\n    if (!el || !chart) return\n    var active = chart.getActiveRenderer ? chart.getActiveRenderer() : 'svg'\n    el.innerHTML =\n      'Bars: <b>' +\n      barCount.toLocaleString() +\n      '</b> &nbsp;·&nbsp; Active renderer: <b>' +\n      active.toUpperCase() +\n      '</b> &nbsp;·&nbsp; DOM nodes in chart: <b>' +\n      domNodeCount().toLocaleString() +\n      '</b> &nbsp;·&nbsp; Render: <b>' +\n      (lastRenderMs > 0 ? lastRenderMs + ' ms' : 'change a control to time it') +\n      '</b>'\n  }\n\n  function rebuild() {\n    barCount = parseInt(document.getElementById('barCount').value, 10)\n    var mode = document.getElementById('rendererMode').value\n\n    barData = generateBars(barCount)\n    options.chart.renderer = mode\n    options.series = [{ name: 'Value', data: barData }]\n    options.title.text =\n      'Column chart: ' +\n      barCount.toLocaleString() +\n      ' bars on the ' +\n      (mode === 'auto' ? 'auto-selected' : mode) +\n      ' renderer'\n\n    var t = performance.now()\n    if (chart) chart.destroy()\n    chart = new ApexCharts(document.querySelector('#chart'), options)\n    me.barChart = chart\n    chart.render().then(function () {\n      if (me.barDisposed) return\n      lastRenderMs = Math.round(performance.now() - t)\n      updateStats()\n    })\n  }\n\n  document.getElementById('rerender').addEventListener('click', rebuild)\n  document.getElementById('rendererMode').addEventListener('change', rebuild)\n  document.getElementById('barCount').addEventListener('change', rebuild)\n  document.getElementById('resetZoom').addEventListener('click', function () {\n    if (chart) chart.resetSeries(true, true)\n  })\n\n  // Initial render into #chart, then fill in the live metrics.\n  chart = new ApexCharts(document.querySelector('#chart'), options)\n  me.barChart = chart\n  chart.render().then(function () {\n    if (me.barDisposed) return\n    updateStats()\n  })\n},\nbeforeDestroy: function () {\n  this.barDisposed = true\n  if (this.barChart) this.barChart.destroy()\n},,\n}\n</script>\n\n<style>\n#chart {\n  max-width: 1000px;\n  margin: 20px auto;\n}\n.panel {\n  max-width: 1000px;\n  margin: 16px auto;\n  font-family: sans-serif;\n}\n.controls {\n  display: flex;\n  gap: 14px;\n  align-items: center;\n  flex-wrap: wrap;\n  margin-bottom: 8px;\n}\n.controls label {\n  font-size: 14px;\n}\n.controls select {\n  padding: 4px 6px;\n  font-size: 14px;\n}\n.controls button {\n  padding: 6px 14px;\n  cursor: pointer;\n}\n.stats {\n  font-family: monospace;\n  font-size: 13px;\n  color: #555;\n  line-height: 1.6;\n}\n.stats b {\n  color: #111;\n}\n.note {\n  background: #f4f8ff;\n  border-left: 3px solid #5b8cff;\n  padding: 10px 14px;\n  font-size: 13px;\n  color: #234;\n  margin-top: 10px;\n  border-radius: 2px;\n}\n.note code {\n  background: #e6eeff;\n  padding: 1px 5px;\n  border-radius: 3px;\n}\n</style>\n"
    }
  ]
}