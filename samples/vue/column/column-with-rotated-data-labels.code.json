  "title": "Column with rotate negative Data Labels",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"bar\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Net Margin',\n          data: [\n            8.2, 12.5, 6.1, -3.4, -9.8, -14.2, -6.5, 2.1, 9.4, 15.8, 11.2, -4.6,\n          ],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          type: 'bar',\n          height: 350,\n        },\n        title: {\n          text: 'Monthly Net Profit Margin',\n          align: 'left',\n        },\n        plotOptions: {\n          bar: {\n            colors: {\n              ranges: [\n                {\n                  from: -30,\n                  to: -8,\n                  color: '#F15B46',\n                },\n                {\n                  from: -8,\n                  to: 0,\n                  color: '#FEB019',\n                },\n              ],\n            },\n            columnWidth: '70%',\n            dataLabels: {\n              orientation: 'vertical',\n              position: 'top', // top, center, bottom\n            },\n          },\n        },\n        dataLabels: {\n          enabled: true,\n          offsetY: 2,\n          formatter: function (val) {\n            return val + '%'\n          },\n          style: {\n            fontSize: '12px',\n            colors: ['#000000'],\n          },\n        },\n        yaxis: {\n          title: {\n            text: 'Net Margin',\n          },\n          labels: {\n            formatter: function (y) {\n              return y.toFixed(0) + '%'\n            },\n          },\n        },\n        xaxis: {\n          type: 'category',\n          categories: [\n            'Jan',\n            'Feb',\n            'Mar',\n            'Apr',\n            'May',\n            'Jun',\n            'Jul',\n            'Aug',\n            'Sep',\n            'Oct',\n            'Nov',\n            'Dec',\n          ],\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
