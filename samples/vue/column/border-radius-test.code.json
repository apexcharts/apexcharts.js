{
  "title": "Rounded Stacked Columns with Negatives",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"bar\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Cloud',\n          data: [30, 42, 38, 55, 48, 60],\n        },\n        {\n          name: 'Hardware',\n          data: [20, -8, 15, 12, -5, 18],\n        },\n        {\n          name: 'Services',\n          data: [15, 22, -10, 18, 25, 20],\n        },\n        {\n          name: 'Licensing',\n          data: [25, 18, 22, 14, 30, 24],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          type: 'bar',\n          height: 350,\n          stacked: true,\n          toolbar: {\n            show: true,\n          },\n        },\n        stroke: {\n          width: 1,\n          colors: ['#fff'],\n        },\n        plotOptions: {\n          bar: {\n            horizontal: false,\n            borderRadius: 10,\n            borderRadiusApplication: 'end',\n            borderRadiusWhenStacked: 'last',\n            dataLabels: {\n              total: {\n                enabled: true,\n                style: {\n                  fontSize: '13px',\n                  fontWeight: 900,\n                },\n              },\n            },\n          },\n        },\n        title: {\n          text: 'Quarterly Profit & Loss by Segment',\n          align: 'left',\n        },\n        xaxis: {\n          categories: [\n            'Q1 2024',\n            'Q2 2024',\n            'Q3 2024',\n            'Q4 2024',\n            'Q1 2025',\n            'Q2 2025',\n          ],\n        },\n        yaxis: {\n          labels: {\n            formatter: function (val) {\n              return '$' + val + 'M'\n            },\n          },\n        },\n        legend: {\n          position: 'right',\n          offsetY: 40,\n        },\n        fill: {\n          opacity: 1,\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
}