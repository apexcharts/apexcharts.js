  "title": "Column with Custom Data Colors",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"bar\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Yearly Profit',\n          data: [\n            {\n              x: '2018',\n              y: 1292,\n            },\n            {\n              x: '2019',\n              y: 4432,\n            },\n            {\n              x: '2020',\n              y: 5423,\n            },\n            {\n              x: '2021',\n              y: 6653,\n            },\n            {\n              x: '2022',\n              y: 8133,\n              fillColor: '#EB8C87',\n              strokeColor: '#C23829',\n            },\n            {\n              x: '2023',\n              y: 7132,\n            },\n            {\n              x: '2024',\n              y: 7332,\n            },\n            {\n              x: '2025',\n              y: 6553,\n            },\n          ],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          height: 350,\n          type: 'bar',\n        },\n        title: {\n          text: 'Yearly Profit',\n          align: 'left',\n        },\n        subtitle: {\n          text: 'Record year highlighted in red',\n          align: 'left',\n        },\n        plotOptions: {\n          bar: {\n            horizontal: false,\n            columnWidth: '60%',\n          },\n        },\n        stroke: {\n          width: 0,\n        },\n        dataLabels: {\n          enabled: false,\n        },\n        yaxis: {\n          labels: {\n            formatter: function (val) {\n              return val / 1000 + 'K $'\n            },\n          },\n        },\n        fill: {\n          opacity: 1,\n        },\n        xaxis: {\n          type: 'datetime',\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
