      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"bar\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Cash Flow',\n          data: [\n            1.45, 5.42, 5.9, -0.42, -12.6, -18.1, -18.2, -14.16, -11.1, -6.09,\n            0.34, 3.88, 13.07, 5.8, 2, 7.37, 8.1, 13.57, 15.75, 17.1, 19.8,\n            -27.03, -54.4, -47.2, -43.3, -18.6, -48.6, -41.1, -39.6, -37.6,\n            -29.4, -21.4, -2.4,\n          ],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          type: 'bar',\n          height: 350,\n        },\n        plotOptions: {\n          bar: {\n            colors: {\n              ranges: [\n                {\n                  from: -100,\n                  to: -46,\n                  color: '#F15B46',\n                },\n                {\n                  from: -45,\n                  to: 0,\n                  color: '#FEB019',\n                },\n              ],\n            },\n            columnWidth: '80%',\n          },\n        },\n        dataLabels: {\n          enabled: false,\n        },\n        yaxis: {\n          title: {\n            text: 'Growth',\n          },\n          labels: {\n            formatter: function (y) {\n              return y.toFixed(0) + '%'\n            },\n          },\n        },\n        xaxis: {\n          type: 'datetime',\n          categories: [\n            '2011-01-01',\n            '2011-02-01',\n            '2011-03-01',\n            '2011-04-01',\n            '2011-05-01',\n            '2011-06-01',\n            '2011-07-01',\n            '2011-08-01',\n            '2011-09-01',\n            '2011-10-01',\n            '2011-11-01',\n    