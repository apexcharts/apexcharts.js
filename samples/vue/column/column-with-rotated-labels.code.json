      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"bar\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Units sold',\n          data: [44, 55, 41, 67, 22, 43, 21, 33, 45, 31, 87, 65, 35],\n        },\n      ],\n      chartOptions: {\n        annotations: {\n          points: [\n            {\n              x: 'Pomegranates',\n              seriesIndex: 0,\n              label: {\n                borderColor: '#775DD0',\n                offsetY: 0,\n                style: {\n                  color: '#fff',\n                  background: '#775DD0',\n                },\n                text: 'Best seller',\n              },\n            },\n          ],\n        },\n        chart: {\n          height: 350,\n          type: 'bar',\n        },\n        title: {\n          text: 'Fruit Sales by Type',\n          align: 'left',\n        },\n        plotOptions: {\n          bar: {\n            borderRadius: 10,\n            columnWidth: '50%',\n          },\n        },\n        dataLabels: {\n          enabled: false,\n        },\n        stroke: {\n          width: 0,\n        },\n        xaxis: {\n          labels: {\n            rotate: -45,\n          },\n          categories: [\n            'Apples',\n            'Oranges',\n            'Strawberries',\n            'Pineapples',\n            'Mangoes',\n            'Bananas',\n            'Blackberries',\n            'Pears',\n            'Watermelons',\n            'Cherries',\n            'Pomegranates',\n            'Tangerines',\n            'Papayas',\n          ],\n          tickPlacement: 'on',\n        },\n        yaxis: {\n          title: {\n            text: 'Units sold (k)',\n          },\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
