{
  "title": "Color-scale Treemap",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"treemap\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          data: [\n            {\n              x: 'INTC',\n              y: 1.2,\n            },\n            {\n              x: 'GS',\n              y: 0.4,\n            },\n            {\n              x: 'CVX',\n              y: -1.4,\n            },\n            {\n              x: 'GE',\n              y: 2.7,\n            },\n            {\n              x: 'CAT',\n              y: -0.3,\n            },\n            {\n              x: 'RTX',\n              y: 5.1,\n            },\n            {\n              x: 'CSCO',\n              y: -2.3,\n            },\n            {\n              x: 'JNJ',\n              y: 2.1,\n            },\n            {\n              x: 'PG',\n              y: 0.3,\n            },\n            {\n              x: 'TRV',\n              y: 0.12,\n            },\n            {\n              x: 'MMM',\n              y: -2.31,\n            },\n            {\n              x: 'NKE',\n              y: 3.98,\n            },\n            {\n              x: 'IYT',\n              y: 1.67,\n            },\n          ],\n        },\n      ],\n      chartOptions: {\n        legend: {\n          show: false,\n        },\n        chart: {\n          height: 350,\n          type: 'treemap',\n        },\n        title: {\n          text: 'Treemap with Color scale',\n        },\n        dataLabels: {\n          enabled: true,\n          style: {\n            fontSize: '12px',\n          },\n          formatter: function (text, op) {\n            return [text, op.value]\n          },\n          offsetY: -4,\n        },\n        plotOptions: {\n          treemap: {\n            enableShades: true,\n            shadeIntensity: 0.5,\n            reverseNegativeShade: true,\n            colorScale: {\n              ranges: [\n                {\n                  from: -6,\n                  to: 0,\n                  color: '#CD363A',\n                },\n                {\n                  from: 0.001,\n                  to: 6,\n                  color: '#52B12C',\n                },\n              ],\n            },\n          },\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
}