{
  "title": "Position Bottom Text Anchor Middle Series Mixed",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"bar\"\n        height=\"380\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          data: [400, 430, 1, -470, 540, 580, -690, 1100, 1200, 1380].map(\n            (_) => _ * -1,\n          ),\n        },\n      ],\n      chartOptions: {\n        chart: {\n          type: 'bar',\n          height: 380,\n        },\n        plotOptions: {\n          bar: {\n            horizontal: true,\n            dataLabels: {\n              position: 'bottom',\n            },\n          },\n        },\n\n        dataLabels: {\n          enabled: true,\n          textAnchor: 'middle',\n          style: {\n            colors: ['#333'],\n          },\n          formatter: function (val, opt) {\n            return opt.w.globals.labels[opt.dataPointIndex] + ':  ' + val\n          },\n        },\n        fill: {\n          opacity: 0.5,\n        },\n        xaxis: {\n          categories: [\n            'South Korea',\n            'Canada',\n            'United Kingdom',\n            'Netherlands',\n            'Italy',\n            'France',\n            'Japan',\n            'United States',\n            'China',\n            'India',\n          ],\n        },\n        yaxis: {\n          labels: {\n            show: false,\n          },\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
}