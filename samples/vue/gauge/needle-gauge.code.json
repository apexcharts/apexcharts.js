{
  "title": "Needle Gauge",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"gauge\"\n        height=\"360\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [68],\n      chartOptions: {\n        chart: {\n          height: 360,\n          type: 'gauge',\n        },\n        plotOptions: {\n          radialBar: {\n            shape: 'needle',\n            startAngle: -135,\n            endAngle: 135,\n            min: 0,\n            max: 100,\n            bands: [\n              { from: 0, to: 30, color: '#FF4560' },\n              { from: 30, to: 70, color: '#FEB019' },\n              { from: 70, to: 100, color: '#00E396' },\n            ],\n            bandsStyle: {\n              strokeWidth: '50%',\n              gap: 1,\n            },\n            ticks: {\n              show: true,\n              major: {\n                count: 11,\n                length: 8,\n                width: 2,\n                color: '#334155',\n                placement: 'outside',\n              },\n              minor: {\n                count: 1,\n                length: 4,\n                width: 1,\n                color: '#94A3B8',\n                placement: 'outside',\n              },\n              labels: {\n                show: true,\n                offset: 6,\n                fontSize: '11px',\n                color: '#334155',\n              },\n            },\n            needle: {\n              color: '#0F172A',\n              length: '60%',\n              baseWidth: 6,\n              tipWidth: 1,\n            },\n            hollow: {\n              margin: 0,\n              size: '70%',\n            },\n            dataLabels: {\n              name: { show: false },\n              value: {\n                offsetY: 32,\n                fontSize: '28px',\n                fontWeight: 700,\n                formatter: function (val) {\n                  return val\n                },\n              },\n            },\n          },\n        },\n        labels: ['Speed'],\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  padding: 0;\n  max-width: 420px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
}