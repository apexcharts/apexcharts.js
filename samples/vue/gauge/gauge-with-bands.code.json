{
  "title": "Gauge with Threshold Bands",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"gauge\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [78],\n      chartOptions: {\n        chart: {\n          height: 350,\n          type: 'gauge',\n        },\n        plotOptions: {\n          radialBar: {\n            startAngle: -135,\n            endAngle: 135,\n            bands: [\n              { from: 0, to: 30, color: '#FF4560' },\n              { from: 30, to: 70, color: '#FEB019' },\n              { from: 70, to: 100, color: '#00E396' },\n            ],\n            bandsStyle: {\n              strokeWidth: '60%',\n              gap: 2,\n            },\n            hollow: {\n              margin: 0,\n              size: '60%',\n            },\n            dataLabels: {\n              name: { show: false },\n              value: {\n                offsetY: 8,\n                fontSize: '32px',\n                fontWeight: 700,\n                formatter: function (val) {\n                  return val + '%'\n                },\n              },\n            },\n          },\n        },\n        fill: { opacity: 0.8 },\n        labels: ['System Health'],\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  padding: 0;\n  max-width: 420px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
}