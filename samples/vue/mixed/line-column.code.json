      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"line\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Website Blog',\n          type: 'column',\n          data: [440, 505, 414, 671, 227, 413, 201, 352, 752, 320, 257, 160],\n        },\n        {\n          name: 'Social Media',\n          type: 'line',\n          data: [23, 42, 35, 27, 43, 22, 17, 31, 22, 22, 12, 16],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          height: 350,\n          type: 'line',\n        },\n        stroke: {\n          width: [0, 4],\n        },\n        title: {\n          text: 'Traffic Sources',\n        },\n        dataLabels: {\n          enabled: true,\n          enabledOnSeries: [1],\n        },\n        labels: [\n          '01 Jan 2024',\n          '02 Jan 2024',\n          '03 Jan 2024',\n          '04 Jan 2024',\n          '05 Jan 2024',\n          '06 Jan 2024',\n          '07 Jan 2024',\n          '08 Jan 2024',\n          '09 Jan 2024',\n          '10 Jan 2024',\n          '11 Jan 2024',\n          '12 Jan 2024',\n        ],\n        yaxis: [\n          {\n            title: {\n              text: 'Website Blog',\n            },\n          },\n          {\n            opposite: true,\n            title: {\n              text: 'Social Media',\n            },\n          },\n        ],\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
