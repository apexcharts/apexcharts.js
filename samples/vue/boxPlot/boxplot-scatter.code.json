      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"boxPlot\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'box',\n          type: 'boxPlot',\n          data: [\n            {\n              x: 'us-east',\n              y: [54, 66, 69, 75, 88],\n              goals: [\n                {\n                  value: 32,\n                  strokeWidth: 0,\n                  strokeHeight: 13,\n                  strokeLineCap: 'round',\n                  strokeColor: '#FEB019',\n                },\n              ],\n            },\n            {\n              x: 'us-west',\n              y: [43, 65, 69, 76, 81],\n              goals: [\n                {\n                  value: 35,\n                  strokeWidth: 0,\n                  strokeHeight: 13,\n                  strokeLineCap: 'round',\n                  strokeColor: '#FEB019',\n                },\n                {\n                  value: 95,\n                  strokeWidth: 0,\n                  strokeHeight: 13,\n                  strokeLineCap: 'round',\n                  strokeColor: '#FEB019',\n                },\n              ],\n            },\n            {\n              x: 'eu-central',\n              y: [31, 39, 45, 51, 59],\n              goals: [\n                {\n                  value: 64,\n                  strokeWidth: 0,\n                  strokeHeight: 13,\n                  strokeLineCap: 'round',\n                  strokeColor: '#FEB019',\n                },\n                {\n                  value: 75,\n                  strokeWidth: 0,\n                  strokeHeight: 13,\n                  strokeLineCap: 'round',\n                  strokeColor: '#FEB019',\n                },\n              ],\n            },\n            {\n              x: 'ap-south',\n              y: [39, 46, 55, 65, 71],\n              goals: [\n                {\n                  value: 27,\n                  strokeWidth: 0,\n                  strokeHeight: 13,\n                  strokeLineCap: 'round',\n                  strokeColor: '#FEB019',\n                },\n                {\n                  value: 77,\n                  strokeWidth: 0,\n                  strokeHeight: 13,\n                  strokeLineCap: 'round',\n                  strokeColor: '#FEB019',\n                },\n              ],\n            },\n            {\n              x: 'sa-east',\n              y: [29, 31, 35, 39, 44],\n              goals: [\n                {\n                  value: 10,\n                  strokeWidth: 0,\n                  strokeHeight: 13,\n                  strokeLineCap: 'round',\n                  strokeColor: '#FEB019',\n                },\n                {\n                  value: 56,\n                  strokeWidth: 0,\n                  strokeHeight: 13,\n                  strokeLineCap: 'round',\n                  strokeColor: '#FEB019',\n                },\n                {\n                  value: 62,\n                  strokeWidth: 0,\n                  strokeHeight: 13,\n                  strokeLineCap: 'round',\n                  strokeColor: '#FEB019',\n                },\n                {\n                  value: 98,\n                  strokeWidth: 0,\n                  strokeHeight: 13,\n                  strokeLineCap: 'round',\n                  strokeColor: '#FEB019',\n                },\n              ],\n            },\n          ],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          type: 'boxPlot',\n          height: 350,\n        },\n        colors: ['#008FFB', '#FEB019'],\n        title: {\n          text: 'Request Latency by Region (ms)',\n          align: 'left',\n        },\n        xaxis: {\n          type: 'category',\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
