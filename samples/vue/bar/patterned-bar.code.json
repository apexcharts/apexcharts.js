{
  "title": "Bar Chart with Pattern Fill",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"bar\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Coal',\n          data: [44, 55, 41, 37, 22, 43, 21],\n        },\n        {\n          name: 'Natural Gas',\n          data: [53, 32, 33, 52, 13, 43, 32],\n        },\n        {\n          name: 'Solar',\n          data: [12, 17, 11, 9, 15, 11, 20],\n        },\n        {\n          name: 'Wind',\n          data: [9, 7, 5, 8, 6, 9, 4],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          type: 'bar',\n          height: 350,\n          stacked: true,\n        },\n        plotOptions: {\n          bar: {\n            horizontal: true,\n            barHeight: '60%',\n          },\n        },\n        dataLabels: {\n          enabled: false,\n        },\n        stroke: {\n          width: 2,\n        },\n        title: {\n          text: 'Electricity Generation by Source',\n        },\n        xaxis: {\n          categories: [2019, 2020, 2021, 2022, 2023, 2024, 2025],\n        },\n        yaxis: {\n          title: {\n            text: undefined,\n          },\n        },\n        tooltip: {\n          shared: false,\n          y: {\n            formatter: function (val) {\n              return val + ' TWh'\n            },\n          },\n        },\n        fill: {\n          type: 'pattern',\n          opacity: 1,\n          pattern: {\n            style: [\n              'circles',\n              'slantedLines',\n              'verticalLines',\n              'horizontalLines',\n            ], // string or array of strings\n          },\n        },\n        states: {\n          hover: {\n            filter: 'none',\n          },\n        },\n        legend: {\n          position: 'right',\n          offsetY: 40,\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
}