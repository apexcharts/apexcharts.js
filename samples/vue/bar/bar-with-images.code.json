{
  "title": "Bar Chart with Images",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"bar\"\n        height=\"410\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Units sold',\n          data: [820, 940, 610, 480, 560, 720, 390, 680, 900, 430, 350, 640],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          type: 'bar',\n          height: 410,\n          animations: {\n            enabled: false,\n          },\n        },\n        plotOptions: {\n          bar: {\n            horizontal: true,\n            barHeight: '100%',\n          },\n        },\n        dataLabels: {\n          enabled: false,\n        },\n        stroke: {\n          width: 1,\n          colors: ['#000'],\n        },\n        yaxis: {\n          axisBorder: {\n            show: false,\n          },\n          axisTicks: {\n            show: false,\n          },\n          title: {\n            text: 'Units sold',\n          },\n        },\n        xaxis: {\n          categories: [\n            'Vanilla',\n            'Chocolate',\n            'Strawberry',\n            'Mint',\n            'Mango',\n            'Coffee',\n            'Pistachio',\n            'Caramel',\n            'Cookies',\n            'Coconut',\n            'Lemon',\n            'Berry',\n          ],\n        },\n        grid: {\n          position: 'back',\n        },\n        title: {\n          text: 'Ice Cream Sales by Flavour',\n          align: 'left',\n        },\n        subtitle: {\n          text: 'Bars filled by a single clipped image',\n          align: 'left',\n        },\n        fill: {\n          type: 'image',\n          opacity: 0.9,\n          image: {\n            src: '../../assets/images/stripes.jpg',\n            width: 640,\n            height: 427,\n          },\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n\n#apexcharts-canvas {\n  margin: 0 auto;\n}\n</style>\n"
    }
  ]
}