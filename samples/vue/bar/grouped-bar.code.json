{
  "title": "Grouped Bar Chart",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"bar\"\n        height=\"430\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Spend',\n          data: [18, 42, 55, 33, 21, 14, 9],\n        },\n        {\n          name: 'Revenue',\n          data: [64, 96, 138, 71, 52, 88, 130],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          type: 'bar',\n          height: 430,\n        },\n        plotOptions: {\n          bar: {\n            horizontal: true,\n            dataLabels: {\n              position: 'top',\n            },\n          },\n        },\n        dataLabels: {\n          enabled: false,\n        },\n        stroke: {\n          show: true,\n          width: 1,\n          colors: ['#fff'],\n        },\n        grid: {\n          padding: {\n            right: 30,\n          },\n        },\n        tooltip: {\n          shared: true,\n          intersect: false,\n        },\n        title: {\n          text: 'Marketing Spend vs Revenue by Channel',\n          align: 'left',\n        },\n        xaxis: {\n          categories: [\n            'Email',\n            'Social',\n            'Search',\n            'Display',\n            'Affiliate',\n            'Referral',\n            'Direct',\n          ],\n          labels: {\n            formatter: function (val) {\n              return '$' + Math.round(val) + 'k'\n            },\n          },\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
}