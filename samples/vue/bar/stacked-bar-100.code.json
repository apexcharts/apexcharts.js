{
  "title": "Stacked Bar Chart",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"bar\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Chrome',\n          data: [44, 55, 41, 37, 22, 43, 21],\n        },\n        {\n          name: 'Safari',\n          data: [53, 32, 33, 52, 13, 43, 32],\n        },\n        {\n          name: 'Edge',\n          data: [12, 17, 11, 9, 15, 11, 20],\n        },\n        {\n          name: 'Firefox',\n          data: [9, 7, 5, 8, 6, 9, 4],\n        },\n        {\n          name: 'Other',\n          data: [25, 12, 19, 32, 25, 24, 10],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          type: 'bar',\n          height: 350,\n          stacked: true,\n          stackType: '100%',\n        },\n        plotOptions: {\n          bar: {\n            horizontal: true,\n          },\n        },\n        stroke: {\n          width: 1,\n          colors: ['#fff'],\n        },\n        title: {\n          text: 'Browser Market Share by Year',\n        },\n        xaxis: {\n          categories: [2019, 2020, 2021, 2022, 2023, 2024, 2025],\n        },\n        tooltip: {\n          y: {\n            formatter: function (val) {\n              return val + 'K'\n            },\n          },\n        },\n        fill: {\n          opacity: 1,\n        },\n        legend: {\n          position: 'top',\n          horizontalAlign: 'left',\n          offsetX: 40,\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
}