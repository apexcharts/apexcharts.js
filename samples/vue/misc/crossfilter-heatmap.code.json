{
  "title": "Crossfilter Heatmap: 2D Cross-Tab that Re-Aggregates (chart.link)",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"cf-wrap\">\n      <div class=\"cf-bar\">\n        <button id=\"cf-reset\">Reset</button>\n        <span class=\"readout\" id=\"cf-readout\"\n          >Click a slice or bar to re-aggregate the heatmap</span\n        >\n      </div>\n\n      <div class=\"cf-card\">\n        <div id=\"chart\">\n          <apexchart\n            type=\"heatmap\"\n            height=\"300\"\n            :options=\"chartOptions\"\n            :series=\"series\"\n          ></apexchart>\n        </div>\n      </div>\n      <div class=\"cf-row\">\n        <div class=\"cf-card\">\n          <div id=\"chart2\">\n            <apexchart\n              type=\"donut\"\n              height=\"250\"\n              :options=\"chartOptions1\"\n              :series=\"series1\"\n            ></apexchart>\n          </div>\n        </div>\n        <div class=\"cf-card\">\n          <div id=\"chart3\">\n            <apexchart\n              type=\"bar\"\n              height=\"250\"\n              :options=\"chartOptions2\"\n              :series=\"series2\"\n            ></apexchart>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"cf-note\">\n        The heatmap is a <b>2D cross-tab</b>: its\n        <code>chart.link.dimension</code> returns <code>[day, quarter]</code>,\n        so the engine aggregates a day-by-quarter matrix of trade counts.\n        Clicking the <b>outcome</b> donut or the <b>day</b> bar re-aggregates\n        the heatmap over just the matching trades and it recolors in place.\n        (Phase A: the heatmap is a re-aggregating target; clicking a heatmap\n        cell to filter is a later phase.) <b>Reset</b> clears everything.\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\nfunction tradesData() {\n  var quarters = ['Q1', 'Q2', 'Q3', 'Q4']\n  var days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri']\n  var out = []\n  for (var i = 0; i < 90; i++) {\n    out.push({\n      quarter: quarters[Math.floor(i / 23) % 4],\n      day: days[i % 5],\n      outcome: i % 3 === 0 ? 'Loss' : 'Gain',\n    })\n  }\n  return out\n}\n\n// Register the shared records BEFORE the charts are constructed.\nApexCharts.crossfilter({ id: 'trades', records: tradesData() })\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [],\nchartOptions: {\nchart: {\n  id: 'byDayQuarter',\n  type: 'heatmap',\n  height: 300,\n  fontFamily: 'Helvetica, Arial, sans-serif',\n  animations: { speed: 450 },\n  link: {\n    id: 'trades',\n    dimension: function (r) { return [r.day, r.quarter] },\n    reduce: 'count',\n  },\n},\ntitle: { text: 'Trades by day x quarter', align: 'left' },\ndataLabels: { enabled: true },\nplotOptions: { heatmap: { radius: 3, enableShades: true, shadeIntensity: 0.6 } },\ncolors: ['#6366f1'],\n},\nseries1: [],\nchartOptions1: {\nchart: {\n  id: 'byOutcome',\n  type: 'donut',\n  height: 250,\n  fontFamily: 'Helvetica, Arial, sans-serif',\n  animations: { speed: 450 },\n  link: { id: 'trades', dimension: function (r) { return r.outcome }, reduce: 'count', dimOpacity: 0.18 },\n},\ntitle: { text: 'Outcome', align: 'left' },\nlegend: { position: 'bottom', fontSize: '12px' },\nplotOptions: { pie: { expandOnClick: false } },\ndataLabels: { enabled: true, formatter: function (v, o) { return o.w.config.series[o.seriesIndex] } },\n// Records are first-seen ordered, and the data emits 'Loss' first, so the\n// domain is [Loss, Gain]: red for Loss, green for Gain.\ncolors: ['#ef4444', '#22c55e'],\n},\nseries2: [],\nchartOptions2: {\nchart: {\n  id: 'byDay',\n  type: 'bar',\n  height: 250,\n  fontFamily: 'Helvetica, Arial, sans-serif',\n  animations: { speed: 450 },\n  link: { id: 'trades', dimension: function (r) { return r.day }, reduce: 'count', seriesName: 'Trades', dimOpacity: 0.18 },\n},\ntitle: { text: 'Day of week', align: 'left' },\nplotOptions: { bar: { columnWidth: '55%', borderRadius: 3, distributed: true } },\nlegend: { show: false },\ndataLabels: { enabled: false },\ncolors: ['#6366f1', '#0ea5e9', '#22c55e', '#f59e0b', '#a855f7'],\n},\ncfTimer: null,\n}\n},\nmounted: function () {\n  // The vue-apexcharts wrapper owns the render, and the crossfilter engine is\n  // registered by the shared head script (ApexCharts.crossfilter). Poll until the\n  // engine exists, then wire the readout + Reset button the same way the vanilla\n  // build does.\n  this.cfTimer = window.setInterval(function () {\n    var cf = ApexCharts.getCrossfilter('trades')\n    if (!cf) return\n    window.clearInterval(this.cfTimer)\n\n    var readout = document.getElementById('cf-readout')\n    cf.on('change', function (state) {\n      var ids = Object.keys(state.filters)\n      readout.textContent =\n        state.filteredCount + ' / ' + state.total + ' trades   (active: ' +\n        (ids.length ? ids.join(', ') : 'none') + ')'\n    })\n    var s = cf.state()\n    readout.textContent = s.filteredCount + ' / ' + s.total + ' trades   (active: none)'\n\n    document.getElementById('cf-reset').addEventListener('click', function () {\n      cf.reset()\n    })\n  }.bind(this), 50)\n},\nbeforeDestroy: function () {\n  window.clearInterval(this.cfTimer)\n},,\n}\n</script>\n\n<style>\n.cf-wrap {\n  max-width: 700px;\n  margin: 12px auto;\n  font-family: Helvetica, Arial, sans-serif;\n}\n.cf-bar {\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  flex-wrap: wrap;\n  margin: 4px 6px 12px;\n}\n.cf-bar button {\n  padding: 6px 13px;\n  cursor: pointer;\n  border: 1px solid #6366f1;\n  color: #4338ca;\n  background: #fff;\n  border-radius: 6px;\n  font-size: 13px;\n  font-weight: 600;\n}\n.cf-bar .readout {\n  font-family: monospace;\n  font-size: 13px;\n  color: #445;\n}\n.cf-card {\n  border: 1px solid #eef;\n  border-radius: 8px;\n  padding: 6px;\n  margin-bottom: 8px;\n}\n.cf-row {\n  display: grid;\n  /* Outcome donut + day bar sit side by side, stacking when the tile narrows. */\n  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));\n  gap: 8px;\n}\n.cf-note {\n  background: #eef2ff;\n  border-left: 3px solid #6366f1;\n  padding: 11px 15px;\n  font-size: 13px;\n  color: #234;\n  border-radius: 2px;\n  line-height: 1.6;\n  margin: 12px 6px;\n}\n.cf-note code {\n  background: #dfe3ff;\n  padding: 1px 5px;\n  border-radius: 3px;\n}\n</style>\n"
    }
  ]
}