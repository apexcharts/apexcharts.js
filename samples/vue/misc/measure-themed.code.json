{
  "title": "Measure Ruler: Themed (config + CSS)",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"oc-card\">\n      <div class=\"oc-bar\">\n        <button id=\"oc-toggle\">Measure</button>\n      </div>\n      <div id=\"chart\">\n        <apexchart\n          type=\"area\"\n          height=\"380\"\n          :options=\"chartOptions\"\n          :series=\"series\"\n        ></apexchart>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\nfunction price() {\n  var out = []\n  var v = 2400\n  for (var i = 0; i < 60; i++) {\n    v += (Math.sin(i / 5) * 60) + (i * 8) - 10\n    out.push([i, Math.round(v)])\n  }\n  return out\n}\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [\n  { name: 'Revenue', data: price() }\n],\nchartOptions: {\nchart: {\n  id: 'themed',\n  type: 'area',\n  height: 380,\n  background: '#0b1220',\n  foreColor: '#93a4bd',\n  fontFamily: \"'Helvetica Neue', Arial, sans-serif\",\n  animations: { enabled: false },\n  toolbar: { show: false },\n  zoom: { enabled: true, type: 'x' },\n  measure: {\n    enabled: true,\n    mode: 'span',\n    // config tokens: brand up/down + currency readout + custom two-line label\n    colors: { up: '#24d1a6', down: '#f0637c' },\n    format: { y: function (v) { return (v >= 0 ? '+' : '') + '$' + Math.abs(v).toLocaleString() } },\n    label: function (info) {\n      var pct = (info.percentChange >= 0 ? '+' : '') + info.percentChange.toFixed(1) + '%'\n      return [\n        (info.dy >= 0 ? '+' : '') + '$' + Math.abs(info.dy).toLocaleString() + '  ' + pct,\n        'sessions ' + info.from.x + ' to ' + info.to.x,\n      ]\n    },\n  },\n},\ntheme: { mode: 'dark' },\nstroke: { width: 2, curve: 'smooth' },\ndataLabels: { enabled: false },\nfill: { type: 'gradient', gradient: { opacityFrom: 0.35, opacityTo: 0.02 } },\ncolors: ['#24d1a6'],\ngrid: { borderColor: '#1c2740' },\ntitle: { text: 'Revenue (drag to measure a move)', align: 'left' },\nxaxis: { type: 'numeric', title: { text: 'Session' } },\nyaxis: { labels: { formatter: function (v) { return '$' + (v / 1000).toFixed(1) + 'k' } } },\n},\npollTimer: null,\n}\n},\nmounted: function () {\n  // The vue-apexcharts wrapper owns the render, so reach the live instance by\n  // its chart.id, then wire the same toggle the vanilla build does. (price()\n  // lives in the shared head script.)\n  var me = this\n  me.pollTimer = window.setInterval(function () {\n    var chart = ApexCharts.getChartByID('themed')\n    if (!chart) return\n    window.clearInterval(me.pollTimer)\n    me.pollTimer = null\n\n    var toggle = document.getElementById('oc-toggle')\n    var on = false\n    toggle.addEventListener('click', function () {\n      on = !on\n      if (on) { chart.startMeasure(); toggle.classList.add('active') }\n      else { chart.stopMeasure(); toggle.classList.remove('active') }\n    })\n  }, 50)\n},\nbeforeDestroy: function () {\n  if (this.pollTimer) window.clearInterval(this.pollTimer)\n},,\n}\n</script>\n\n<style>\n/* The card sets a dark surface and overrides the ruler's CSS custom\n     properties + element classes to match. This is the \"style it to match your\n     app\" path; the chart also passes config tokens (colors, currency format,\n     custom label). */\n.oc-card {\n  max-width: 820px;\n  margin: 16px auto;\n  padding: 8px 8px 2px;\n  border-radius: 14px;\n  background: #0b1220;\n  font-family: 'Helvetica Neue', Arial, sans-serif;\n  --apx-measure-guide: #3b4a63;\n}\n.oc-card .apexcharts-title-text {\n  fill: #e7ecf5;\n}\n.oc-card .apexcharts-text tspan {\n  fill: #93a4bd;\n}\n/* Ruler theming via the element classes */\n.oc-card .apexcharts-measure-band {\n  fill-opacity: 0.16;\n}\n.oc-card .apexcharts-measure-vline {\n  stroke-dasharray: 2;\n  stroke-opacity: 0.7;\n}\n.oc-card .apexcharts-measure-label-bg {\n  fill: #111b2e;\n  fill-opacity: 0.96;\n  rx: 7;\n}\n.oc-card .apexcharts-measure-label tspan {\n  fill: #e7ecf5;\n  font-weight: 600;\n}\n.oc-bar {\n  display: flex;\n  gap: 10px;\n  align-items: center;\n  margin: 8px 10px;\n}\n.oc-bar button {\n  padding: 6px 13px;\n  cursor: pointer;\n  border: 1px solid #24d1a6;\n  color: #24d1a6;\n  background: transparent;\n  border-radius: 8px;\n  font-size: 13px;\n  font-weight: 600;\n}\n.oc-bar button.active {\n  background: #24d1a6;\n  color: #06121f;\n}\n</style>\n"
    }
  ]
}