{
  "title": "Weave Plugin Platform (custom plugin drawing into its own layer)",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"panel\">\n      <div class=\"controls\">\n        <button id=\"newData\">New data</button>\n        <span class=\"readout\" id=\"readout\"\n          >Mean line drawn by the plugin. Press New data to recompute.</span\n        >\n      </div>\n    </div>\n\n    <div id=\"chart\">\n      <apexchart\n        type=\"line\"\n        height=\"380\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n\n    <div class=\"panel\">\n      <div class=\"note\">\n        The dashed mean line is not part of the chart: it is drawn by a plugin\n        registered with\n        <code>ApexCharts.registerPlugin(&#123; name, setup &#125;)</code> and\n        activated via <code>plugins: [&#123; name: 'mean-line' &#125;]</code>.\n        On every <code>draw</code> hook the plugin reads <code>api.data</code>,\n        converts the mean to a pixel with <code>api.scales.y()</code>, paints\n        into its own <code>api.layer()</code>, and reports the value back\n        through <code>api.emit()</code>. Press New data: the plugin recomputes\n        and redraws.\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\n// Weave (#1): a third-party plugin registered ONCE, globally, by name. It\n// never touches internal state: it subscribes to the 'draw' lifecycle hook\n// and paints into its own sandboxed layer using the api (scales, data, theme,\n// emit). Activate it per-chart via the top-level plugins array.\nApexCharts.registerPlugin({\n  name: 'mean-line',\n  apiVersion: 1,\n  setup(api) {\n    api.on('draw', function (ctx) {\n      var scales = ctx.scales\n      var data = ctx.data\n      if (!scales || !data || !data.length) return\n\n      var layer = api.layer({ z: 'front' })\n      layer.clear()\n\n      var series = data.filter(function (s) { return !s.hidden })[0]\n      if (!series || !series.points.length) return\n\n      var sum = 0\n      var n = 0\n      series.points.forEach(function (p) {\n        if (p.y != null) { sum += p.y; n++ }\n      })\n      if (!n) return\n\n      var mean = sum / n\n      var y = scales.y(mean)\n      var accent = api.theme.token('accent') || '#0e9d9a'\n\n      layer.line({\n        x1: 0, y1: y, x2: scales.gridWidth, y2: y,\n        stroke: accent, width: 2, dash: 5,\n      })\n      layer.text({\n        x: scales.gridWidth - 6, y: y - 7,\n        text: 'mean ' + mean.toFixed(1),\n        color: accent, size: 12, anchor: 'end', weight: 600,\n      })\n\n      // hand the computed value back to the page via a custom event; it\n      // fires namespaced as 'plugin:mean-line:meanComputed' so plugin events\n      // can never collide with the chart's internal lifecycle events\n      api.emit('meanComputed', { value: mean })\n    })\n  },\n})\n\nfunction randomSeries() {\n  var d = []\n  for (var i = 0; i < 8; i++) d.push(Math.round(20 + Math.random() * 80))\n  return d\n}\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [\n  { name: 'Value', data: [42, 61, 38, 74, 55, 48, 67, 52] }\n],\nchartOptions: {\nchart: {\n  id: 'weaveChart',\n  height: 380,\n  type: 'line',\n  animations: { enabled: true },\n  toolbar: { show: false },\n},\ncolors: ['#0e9d9a'],\nstroke: { curve: 'smooth', width: 3 },\nmarkers: { size: 4 },\ntitle: { text: 'Series with a plugin-drawn mean line', align: 'left' },\nsubtitle: { text: 'The mean line comes from a Weave plugin, not the chart config', align: 'left' },\nxaxis: { categories: [1, 2, 3, 4, 5, 6, 7, 8] },\nplugins: [\n  { name: 'mean-line' }\n],\n},\n}\n},\nmounted: function () {\n  // The vue-apexcharts wrapper owns the render, so reach the live instance by\n  // its chart.id. Poll until it exists, then wire the same UI the vanilla build\n  // does. (The mean-line plugin is registered ONCE in the shared head script,\n  // before any chart is created, and randomSeries lives there too.)\n  var timer = window.setInterval(function () {\n    var chart = ApexCharts.getChartByID('weaveChart')\n    if (!chart) return\n    window.clearInterval(timer)\n\n    var readout = document.getElementById('readout')\n\n    chart.addEventListener('plugin:mean-line:meanComputed', function (c, payload) {\n      var detail = payload && payload.value != null ? payload : (c && c.value != null ? c : null)\n      var v = detail ? detail.value : null\n      if (v != null) {\n        readout.innerHTML = 'plugin mean-line emitted: <b>mean = ' + v.toFixed(1) + '</b>'\n      }\n    })\n\n    document.getElementById('newData').addEventListener('click', function () {\n      chart.updateSeries([{ name: 'Value', data: randomSeries() }])\n    })\n  }, 50)\n},,\n}\n</script>\n\n<style>\n#chart {\n  max-width: 760px;\n  margin: 16px auto;\n}\n.panel {\n  max-width: 760px;\n  margin: 16px auto;\n  font-family: sans-serif;\n}\n.controls {\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  flex-wrap: wrap;\n  margin-bottom: 8px;\n}\n.controls button {\n  padding: 7px 16px;\n  cursor: pointer;\n  border: 1px solid #cdd3de;\n  background: #fff;\n  border-radius: 6px;\n  font-size: 14px;\n}\n.readout {\n  font-family: monospace;\n  font-size: 13px;\n  color: #444;\n}\n.readout b {\n  color: #111;\n}\n.note {\n  background: #f0fbfa;\n  border-left: 3px solid #0e9d9a;\n  padding: 10px 14px;\n  font-size: 13px;\n  color: #234;\n  border-radius: 2px;\n  margin-top: 12px;\n  line-height: 1.55;\n}\n.note code {\n  background: #d7f2f0;\n  padding: 1px 5px;\n  border-radius: 3px;\n}\n</style>\n"
    }
  ]
}