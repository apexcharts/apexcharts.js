{
  "title": "Measure Ruler: Persist and Share Pinned Rulers",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"mp-panel\">\n      <div class=\"mp-bar\">\n        <button id=\"mp-toggle\">Measure</button>\n        <button id=\"mp-clear\">Clear</button>\n        <button id=\"mp-undo\">Undo</button>\n        <button id=\"mp-redo\">Redo</button>\n        <button id=\"mp-share\">Copy shareable link</button>\n        <span class=\"readout\" id=\"mp-readout\"\n          >Turn on Measure and drag A to B, then share or undo</span\n        >\n      </div>\n      <div class=\"mp-link\" id=\"mp-link\"></div>\n    </div>\n\n    <div id=\"chart\">\n      <apexchart\n        type=\"line\"\n        height=\"380\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n\n    <div class=\"mp-panel\">\n      <div class=\"mp-note\">\n        Draw one or more rulers, then <b>Copy shareable link</b>\n        (<code>chart.perspectives.toURL()</code>): the rulers travel in the\n        <code>#apex=</code> URL fragment alongside the zoom window, so opening\n        that link elsewhere restores the exact drawing on load via\n        <code>ApexCharts.perspectives.fromURL()</code>. Because\n        <code>chart.history.enabled</code> is on, every pin is an undo step:\n        <b>Undo</b> / <b>Redo</b> (or <code>Ctrl</code>+<code>Z</code>) steps\n        through them. Pins are stored in data coordinates, so a restored ruler\n        re-projects at whatever zoom the view lands in.\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\n// Pinned measure rulers live in data space on the chart, not in your app, so\n// they can be captured into the shared view state: Perspectives carries them\n// in a URL and Rewind (history) makes each pin an undo step.\nfunction series() {\n  var out = []\n  var v = 2400\n  for (var i = 0; i < 60; i++) {\n    v += Math.sin(i / 5) * 40 + i * 6 - 8\n    out.push([i, Math.round(v)])\n  }\n  return out\n}\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [\n  { name: 'Revenue', data: series() }\n],\nchartOptions: {\nchart: {\n  id: 'measure-persist',\n  type: 'line',\n  height: 380,\n  fontFamily: 'Helvetica, Arial, sans-serif',\n  animations: { enabled: true },\n  measure: { enabled: true, pinOnRelease: true },\n  history: { enabled: true },\n  toolbar: { show: true, tools: { zoom: true, pan: true, reset: true, download: false } },\n  zoom: { enabled: true, type: 'x' },\n},\nstroke: { width: 2, curve: 'straight' },\ncolors: ['#0ea5e9'],\ndataLabels: { enabled: false },\ntitle: { text: 'Revenue (draw rulers, then share or undo)', align: 'left' },\nxaxis: { type: 'numeric', title: { text: 'Session' } },\nyaxis: { title: { text: 'Revenue' }, decimalsInFloat: 0 },\n},\npollTimer: null,\n}\n},\nmounted: function () {\n  // The vue-apexcharts wrapper owns the render, so reach the live instance by\n  // its chart.id, then wire the same persistence/share/undo controls the\n  // vanilla build does. (series() lives in the shared head script.)\n  var me = this\n  me.pollTimer = window.setInterval(function () {\n    var chart = ApexCharts.getChartByID('measure-persist')\n    if (!chart) return\n    window.clearInterval(me.pollTimer)\n    me.pollTimer = null\n\n    var on = false\n    var toggle = document.getElementById('mp-toggle')\n    var readout = document.getElementById('mp-readout')\n    var linkEl = document.getElementById('mp-link')\n\n    function refreshHistoryButtons() {\n      if (!chart.history) return\n      document.getElementById('mp-undo').disabled = !chart.history.canUndo()\n      document.getElementById('mp-redo').disabled = !chart.history.canRedo()\n    }\n\n    toggle.addEventListener('click', function () {\n      on = !on\n      if (on) {\n        chart.startMeasure()\n        toggle.classList.add('active')\n        readout.textContent = 'Drag from A to B on the chart'\n      } else {\n        chart.stopMeasure()\n        toggle.classList.remove('active')\n      }\n    })\n\n    document.getElementById('mp-clear').addEventListener('click', function () {\n      chart.clearMeasures()\n    })\n\n    document.getElementById('mp-undo').addEventListener('click', function () {\n      if (chart.history) chart.history.undo()\n    })\n\n    document.getElementById('mp-redo').addEventListener('click', function () {\n      if (chart.history) chart.history.redo()\n    })\n\n    document.getElementById('mp-share').addEventListener('click', function () {\n      var url = chart.perspectives.toURL()\n      linkEl.textContent = url\n      if (navigator.clipboard) navigator.clipboard.writeText(url).catch(function () {})\n    })\n\n    chart.addEventListener('measured', function () {\n      readout.textContent = 'Pinned. Share the link or press Undo (Ctrl+Z).'\n    })\n\n    // Keep Undo/Redo in sync with keyboard shortcuts too.\n    chart.addEventListener('historyChange', refreshHistoryButtons)\n\n    // Restore a shared drawing if the page was opened with a #apex= fragment.\n    try {\n      var shared = ApexCharts.perspectives && ApexCharts.perspectives.fromURL()\n      if (shared) chart.perspectives.apply(shared, { animate: false })\n    } catch (e) {}\n\n    refreshHistoryButtons()\n  }, 50)\n},\nbeforeDestroy: function () {\n  if (this.pollTimer) window.clearInterval(this.pollTimer)\n},,\n}\n</script>\n\n<style>\n#chart {\n  max-width: 780px;\n  margin: 12px auto;\n}\n.mp-panel {\n  max-width: 780px;\n  margin: 12px auto;\n  font-family: Helvetica, Arial, sans-serif;\n}\n.mp-bar {\n  display: flex;\n  gap: 8px;\n  align-items: center;\n  flex-wrap: wrap;\n  margin: 6px 6px 8px;\n}\n.mp-bar button {\n  padding: 6px 13px;\n  cursor: pointer;\n  border: 1px solid #0ea5e9;\n  color: #0369a1;\n  background: #fff;\n  border-radius: 6px;\n  font-size: 13px;\n  font-weight: 600;\n}\n.mp-bar button.active {\n  background: #0ea5e9;\n  color: #fff;\n}\n.mp-bar button:disabled {\n  opacity: 0.4;\n  cursor: default;\n}\n.mp-bar .readout {\n  font-family: monospace;\n  font-size: 13px;\n  color: #445;\n}\n.mp-link {\n  font-family: monospace;\n  font-size: 12px;\n  color: #555;\n  word-break: break-all;\n  margin: 0 6px 6px;\n}\n.mp-note {\n  background: #f0f9ff;\n  border-left: 3px solid #0ea5e9;\n  padding: 11px 15px;\n  font-size: 13px;\n  color: #234;\n  border-radius: 2px;\n  line-height: 1.6;\n  margin: 12px 6px;\n}\n.mp-note code {\n  background: #dceafb;\n  padding: 1px 5px;\n  border-radius: 3px;\n}\n</style>\n"
    }
  ]
}