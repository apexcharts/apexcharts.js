{
  "title": "Design Tokens and OS-Aware Theming (Facet)",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"panel\">\n      <div class=\"controls\">\n        <button id=\"toggle\">Toggle light / dark</button>\n        <button id=\"shuffle\">Shuffle accent token</button>\n        <span id=\"state\" class=\"state\"></span>\n      </div>\n    </div>\n\n    <div id=\"chart\">\n      <apexchart\n        type=\"area\"\n        height=\"400\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n\n    <div class=\"panel\">\n      <div class=\"note\">\n        Every color here comes from CSS <code>--apx-*</code> tokens\n        (<code>--apx-accent</code>, <code>--apx-fore</code>,\n        <code>--apx-grid</code>, <code>--apx-surface</code>) defined once in the\n        stylesheet. The chart config sets no colors at all. The first button\n        flips a class that swaps the token values; with\n        <code>theme: &#123; follow: 'os' &#125;</code> the chart also tracks the\n        OS <code>prefers-color-scheme</code> automatically, no JS required.\n        <b>Shuffle accent token</b> changes only the CSS variable at runtime and\n        calls <code>chart.refreshTokens()</code>, which re-reads the cascade and\n        re-renders: the path for design-system theme switches that are not an OS\n        color-scheme flip.\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\n// No per-series colors, no foreColor, no grid.borderColor: the chart reads the\n// --apx-* tokens from the cascade. theme.follow:'os' additionally tracks the\n// operating system's light/dark setting with zero JS.\n// Shared by the vanilla-js, React and Vue builds: the accent tokens the\n// Shuffle button cycles through at runtime.\nvar ACCENTS = ['#e11d48', '#0e9d9a', '#d97706', '#7c3aed', '#4f46e5']\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [\n  { name: 'Users', data: [3100, 4200, 3800, 5100, 4700, 6200, 5800] }\n],\nchartOptions: {\nchart: {\n  id: 'facetTokensChart',\n  height: 400,\n  type: 'area',\n  fontFamily: 'sans-serif',\n  animations: { enabled: true },\n  toolbar: { show: false },\n},\ntheme: {\n  follow: 'os',\n},\nstroke: { curve: 'smooth', width: 2 },\nfill: { type: 'gradient', gradient: { opacityFrom: 0.35, opacityTo: 0.05 } },\ndataLabels: { enabled: false },\ntitle: {\n  text: 'Weekly active users',\n  align: 'left',\n},\nsubtitle: {\n  text: 'Colors come entirely from CSS --apx-* design tokens',\n  align: 'left',\n},\nxaxis: {\n  type: 'category',\n  categories: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],\n},\ngrid: {\n  borderColor: '#e0e0e0',\n},\n},\n}\n},\nmounted: function () {\n  // The vue-apexcharts wrapper owns the render, so reach the live instance by\n  // its chart.id at event time. (ACCENTS lives in the shared head script.)\n  var root = document.documentElement\n  var stateEl = document.getElementById('state')\n  var accentIdx = -1\n\n  function currentMode() {\n    return root.classList.contains('apx-dark') ? 'dark' : 'light'\n  }\n  function syncState() {\n    stateEl.textContent = 'Current: ' + currentMode()\n  }\n  syncState()\n\n  var onToggle = function () {\n    root.classList.toggle('apx-dark')\n    var chart = ApexCharts.getChartByID('facetTokensChart')\n    if (chart) chart.updateOptions({ theme: { mode: currentMode() } })\n    syncState()\n  }\n  var onShuffle = function () {\n    accentIdx = (accentIdx + 1) % ACCENTS.length\n    root.style.setProperty('--apx-accent', ACCENTS[accentIdx])\n    var chart = ApexCharts.getChartByID('facetTokensChart')\n    if (chart) chart.refreshTokens()\n  }\n\n  var toggleBtn = document.getElementById('toggle')\n  var shuffleBtn = document.getElementById('shuffle')\n  toggleBtn.addEventListener('click', onToggle)\n  shuffleBtn.addEventListener('click', onShuffle)\n\n  this._toggleBtn = toggleBtn\n  this._shuffleBtn = shuffleBtn\n  this._onToggle = onToggle\n  this._onShuffle = onShuffle\n},\nbeforeDestroy: function () {\n  if (this._toggleBtn) this._toggleBtn.removeEventListener('click', this._onToggle)\n  if (this._shuffleBtn) this._shuffleBtn.removeEventListener('click', this._onShuffle)\n},,\n}\n</script>\n\n<style>\n/* Facet (#13): define the chart's colors as CSS design tokens ONCE. Every\n     ApexCharts instance on the page reads them, so the chart is part of your\n     design system, not a separate color config. */\n:root {\n  --apx-accent: #4f46e5;\n  --apx-fore: #1f2937;\n  --apx-grid: #e5e7eb;\n  --apx-surface: #ffffff;\n  --page-bg: #ffffff;\n  --page-fore: #1f2937;\n}\n/* The dark palette: the same tokens, different values. Toggling the theme\n     needs no per-series color config in JS. */\n:root.apx-dark {\n  --apx-accent: #818cf8;\n  --apx-fore: #e5e7eb;\n  --apx-grid: #374151;\n  --apx-surface: #0b0f19;\n  --page-bg: #0b0f19;\n  --page-fore: #e5e7eb;\n}\n\nbody {\n  background: var(--page-bg);\n  color: var(--page-fore);\n  transition:\n    background 0.25s ease,\n    color 0.25s ease;\n}\n#chart {\n  max-width: 720px;\n  margin: 16px auto;\n}\n.panel {\n  max-width: 720px;\n  margin: 16px auto;\n  font-family: sans-serif;\n}\n.controls {\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  margin-bottom: 8px;\n}\n.controls button {\n  padding: 7px 16px;\n  cursor: pointer;\n  border: 1px solid var(--apx-grid);\n  background: var(--apx-surface);\n  color: var(--page-fore);\n  border-radius: 6px;\n  font-size: 14px;\n}\n.note {\n  border-left: 3px solid var(--apx-accent);\n  padding: 10px 14px;\n  font-size: 13px;\n  line-height: 1.55;\n  background: color-mix(in srgb, var(--apx-accent) 8%, transparent);\n  border-radius: 2px;\n}\n.note code {\n  background: color-mix(in srgb, var(--apx-accent) 16%, transparent);\n  padding: 1px 5px;\n  border-radius: 3px;\n}\n.state {\n  font-size: 13px;\n}\n</style>\n"
    }
  ]
}