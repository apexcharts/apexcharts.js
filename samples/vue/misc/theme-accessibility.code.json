      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"wrapper\">\n      <h2>Default palette</h2>\n      <p class=\"desc\">\n        Standard <code>palette1</code> — no accessibility mode set.\n      </p>\n      <div id=\"chart-default\">\n        <apexchart\n          type=\"bar\"\n          height=\"220\"\n          :options=\"chartOptions\"\n          :series=\"series\"\n        ></apexchart>\n      </div>\n\n      <h2 style=\"margin-top: 32px\">Color Blind Modes</h2>\n      <p class=\"desc\">\n        Set via <code>theme.accessibility.colorBlindMode</code>. Each palette is\n        designed to remain distinguishable under the named color vision\n        deficiency.\n      </p>\n\n      <div class=\"grid\">\n        <div class=\"card\">\n          <h3>Deuteranopia</h3>\n          <p>Red-green (green-weak) · ~6% of males</p>\n          <div id=\"chart-deuteranopia\">\n            <apexchart\n              type=\"bar\"\n              height=\"200\"\n              :options=\"chartOptionsDeuteranopia\"\n              :series=\"seriesDeuteranopia\"\n            ></apexchart>\n          </div>\n        </div>\n        <div class=\"card\">\n          <h3>Protanopia</h3>\n          <p>Red-green (red-weak) · ~1% of males</p>\n          <div id=\"chart-protanopia\">\n            <apexchart\n              type=\"bar\"\n              height=\"200\"\n              :options=\"chartOptionsProtanopia\"\n              :series=\"seriesProtanopia\"\n            ></apexchart>\n          </div>\n        </div>\n        <div class=\"card\">\n          <h3>Tritanopia</h3>\n          <p>Blue-yellow · ~0.01% of population</p>\n          <div id=\"chart-tritanopia\">\n            <apexchart\n              type=\"bar\"\n              height=\"200\"\n              :options=\"chartOptionsTritanopia\"\n              :series=\"seriesTritanopia\"\n            ></apexchart>\n          </div>\n        </div>\n        <div class=\"card\">\n          <h3>High Contrast</h3>\n          <p>Wider strokes · data labels always on</p>\n          <div id=\"chart-highContrast\">\n            <apexchart\n              type=\"bar\"\n              height=\"200\"\n              :options=\"chartOptionsHighContrast\"\n              :series=\"seriesHighContrast\"\n            ></apexchart>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Product A',\n          data: [44, 55, 41, 64, 22, 43],\n        },\n        {\n          name: 'Product B',\n          data: [53, 32, 33, 52, 13, 44],\n        },\n        {\n          name: 'Product C',\n          data: [12, 17, 11, 9, 15, 11],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          type: 'bar',\n          height: 220,\n          toolbar: { show: false },\n        },\n        title: {\n          text: 'Monthly Revenue (default palette)',\n          style: { fontSize: '13px' },\n        },\n        plotOptions: {\n          bar: { columnWidth: '55%', borderRadius: 3 },\n        },\n        dataLabels: { enabled: false },\n        xaxis: {\n          categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],\n        },\n        legend: { position: 'top' },\n      },\n      seriesDeuteranopia: [\n        {\n          name: 'Product A',\n          data: [44, 55, 41, 64, 22, 43],\n        },\n        {\n          name: 'Product B',\n          data: [53, 32, 33, 52, 13, 44],\n        },\n        {\n          name: 'Product C',\n          data: [12, 17, 11, 9, 15, 11],\n        },\n      ],\n      chartOptionsDeuteranopia: {\n        chart: {\n          type: 'bar',\n          height: 200,\n          toolbar: { show: false },\n        },\n        plotOptions: {\n          bar: { columnWidth: '55%', borderRadius: 3 },\n        },\n        dataLabels: { enabled: false },\n        xaxis: {\n          categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],\n        },\n        legend: { show: false },\n        theme: {\n          accessibility: { colorBlindMode: 'deuteranopia' },\n        },\n      },\n      seriesProtanopia: [\n        {\n          name: 'Product A',\n          data: [44, 55, 41, 64, 22, 43],\n        },\n        {\n          name: 'Product B',\n          data: [53, 32, 33, 52, 13, 44],\n        },\n        {\n          name: 'Product C',\n          data: [12, 17, 11, 9, 15, 11],\n        },\n      ],\n      chartOptionsProtanopia: {\n        chart: {\n          type: 'bar',\n          height: 200,\n          toolbar: { show: false },\n        },\n        plotOptions: {\n          bar: { columnWidth: '55%', borderRadius: 3 },\n        },\n        dataLabels: { enabled: false },\n        xaxis: {\n          categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],\n        },\n        legend: { show: false },\n        theme: {\n          accessibility: { colorBlindMode: 'protanopia' },\n        },\n      },\n      seriesTritanopia: [\n        {\n          name: 'Product A',\n          data: [44, 55, 41, 64, 22, 43],\n        },\n        {\n          name: 'Product B',\n          data: [53, 32, 33, 52, 13, 44],\n        },\n        {\n          name: 'Product C',\n          data: [12, 17, 11, 9, 15, 11],\n        },\n      ],\n      chartOptionsTritanopia: {\n        chart: {\n          type: 'bar',\n          height: 200,\n          toolbar: { show: false },\n        },\n        plotOptions: {\n          bar: { columnWidth: '55%', borderRadius: 3 },\n        },\n        dataLabels: { enabled: false },\n        xaxis: {\n          categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],\n        },\n        legend: { show: false },\n        theme: {\n          accessibility: { colorBlindMode: 'tritanopia' },\n        },\n      },\n      seriesHighContrast: [\n        {\n          name: 'Product A',\n          data: [44, 55, 41, 64, 22, 43],\n        },\n        {\n          name: 'Product B',\n          data: [53, 32, 33, 52, 13, 44],\n        },\n        {\n          name: 'Product C',\n          data: [12, 17, 11, 9, 15, 11],\n        },\n      ],\n      chartOptionsHighContrast: {\n        chart: {\n          type: 'bar',\n          height: 200,\n          toolbar: { show: false },\n        },\n        plotOptions: {\n          bar: { columnWidth: '55%', borderRadius: 3 },\n        },\n        xaxis: {\n          categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],\n        },\n        legend: { show: false },\n        theme: {\n          accessibility: { colorBlindMode: 'highContrast' },\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#wrapper {\n  max-width: 900px;\n  margin: 35px auto;\n  padding: 24px;\n  background: #fff;\n  border: 1px solid #e0e0e0;\n  border-radius: 8px;\n  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.07);\n}\n\nh2 {\n  font-family: sans-serif;\n  font-size: 18px;\n  font-weight: 600;\n  color: #333;\n  margin: 32px 0 4px;\n}\n\nh2:first-child {\n  margin-top: 0;\n}\n\np.desc {\n  font-family: sans-serif;\n  font-size: 13px;\n  color: #777;\n  margin: 0 0 12px;\n}\n\n.grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 24px;\n}\n\n.card {\n  border: 1px solid #eee;\n  border-radius: 6px;\n  padding: 12px;\n}\n\n.card h3 {\n  font-family: sans-serif;\n  font-size: 13px;\n  font-weight: 600;\n  color: #444;\n  margin: 0 0 2px;\n  text-transform: uppercase;\n  letter-spacing: 0.5px;\n}\n\n.card p {\n  font-family: sans-serif;\n  font-size: 12px;\n  color: #999;\n  margin: 0 0 8px;\n}\n</style>\n"
