{
  "title": "Momentum: Pinch Zoom, Two-Finger Pan and Kinetic Inertia",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"panel\">\n      <div class=\"readout\">\n        <span class=\"pill\" id=\"gesture\">ready</span>\n        <span>window: <b id=\"window\">full range</b></span>\n      </div>\n\n      <div class=\"gestures\">\n        <div class=\"gesture\">\n          <h4>Pinch</h4>\n          <p>\n            Two fingers, spread or squeeze. Zooms the x-axis around the point\n            between your fingers, frame by frame.\n          </p>\n        </div>\n        <div class=\"gesture\">\n          <h4>Two-finger drag</h4>\n          <p>\n            Slide both fingers together to pan while pinched. The point under\n            your fingers stays put.\n          </p>\n        </div>\n        <div class=\"gesture\">\n          <h4>Flick to glide</h4>\n          <p>\n            In pan mode, drag with one finger and release with speed. The chart\n            keeps gliding and eases to a stop at the data edge.\n          </p>\n        </div>\n      </div>\n    </div>\n\n    <div id=\"chart\">\n      <apexchart\n        type=\"area\"\n        height=\"400\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n\n    <div class=\"panel\">\n      <div class=\"note\">\n        Momentum is on by default: <code>chart.zoom.pinch</code> and\n        <code>chart.pan.inertia</code>. Pinch-zoom and kinetic inertia are\n        <b>touch gestures</b>, so try this on a phone or tablet, or turn on\n        device (touch) emulation in your browser dev tools. On desktop you can\n        still mouse-wheel zoom and use the toolbar's pan tool; the readout above\n        tracks the x-window from the <code>zoomed</code> and\n        <code>scrolled</code> events. A one-finger drag that is mostly vertical\n        is treated as a page scroll (axis rails), so the chart never traps the\n        page.\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\n// A deterministic daily time series (no randomness, so the demo is stable).\n// Enough points that a pinch/pan actually has somewhere to go.\nfunction momentumSeries() {\n  var out = []\n  var start = new Date('2023-01-01').getTime()\n  var day = 86400000\n  var v = 120\n  for (var i = 0; i < 220; i++) {\n    // smooth composite drift: a couple of sines plus a slow trend\n    v =\n      120 +\n      38 * Math.sin(i / 13) +\n      18 * Math.sin(i / 4.5) +\n      i * 0.32\n    out.push([start + i * day, Math.round(v * 100) / 100])\n  }\n  return out\n}\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [\n  { name: 'Reading', data: momentumSeries() }\n],\nchartOptions: {\nchart: {\n  id: 'momentumChart',\n  height: 400,\n  type: 'area',\n  fontFamily: 'Helvetica, Arial, sans-serif',\n  animations: { enabled: false },\n  toolbar: {\n    autoSelected: 'pan',\n    tools: { pan: true, zoom: true, zoomin: true, zoomout: true, reset: true, download: false },\n  },\n  zoom: {\n    enabled: true,\n    type: 'x',\n    pinch: true,\n  },\n  pan: {\n    inertia: true,\n    friction: 0.92,\n  },\n},\ncolors: ['#4f46e5'],\ndataLabels: { enabled: false },\nstroke: { curve: 'smooth', width: 2 },\nfill: {\n  type: 'gradient',\n  gradient: { shadeIntensity: 0.3, opacityFrom: 0.35, opacityTo: 0.03, stops: [0, 100] },\n},\ntitle: { text: 'Sensor reading (220 days)', align: 'left' },\nsubtitle: { text: 'Pinch to zoom, two-finger pan, flick to glide', align: 'left' },\nxaxis: {\n  type: 'datetime',\n},\nyaxis: {\n  labels: { formatter: function (v) { return Math.round(v) } },\n},\ntooltip: { x: { format: 'dd MMM yyyy' } },\n},\n}\n},\nmounted: function () {\n  // The vue-apexcharts wrapper owns the render, so reach the live instance by\n  // its chart.id. Poll until it exists, then wire the same readout the vanilla\n  // build does. (momentumSeries lives in the shared head script.)\n  var timer = window.setInterval(function () {\n    var chart = ApexCharts.getChartByID('momentumChart')\n    if (!chart) return\n    window.clearInterval(timer)\n\n    var gestureEl = document.getElementById('gesture')\n    var windowEl = document.getElementById('window')\n\n    function fmt(ts) {\n      return new Date(ts).toISOString().slice(0, 10)\n    }\n    function showWindow(label, xaxis) {\n      gestureEl.innerHTML = label\n      if (xaxis && xaxis.min != null && xaxis.max != null) {\n        windowEl.innerHTML = fmt(xaxis.min) + '  to  ' + fmt(xaxis.max)\n      }\n    }\n\n    // zoomed fires at the end of a pinch (and on wheel / toolbar zoom); scrolled\n    // fires continuously while panning and once the inertia glide comes to rest.\n    chart.addEventListener('zoomed', function (c, opts) {\n      showWindow('zoomed', opts.xaxis)\n    })\n    chart.addEventListener('scrolled', function (c, opts) {\n      showWindow('panned', opts.xaxis)\n    })\n  }, 50)\n},,\n}\n</script>\n\n<style>\n#chart {\n  max-width: 820px;\n  margin: 16px auto;\n}\n.panel {\n  max-width: 820px;\n  margin: 16px auto;\n  font-family: sans-serif;\n}\n.readout {\n  display: flex;\n  gap: 18px;\n  align-items: center;\n  flex-wrap: wrap;\n  font-size: 13px;\n  color: #334;\n  margin-bottom: 6px;\n}\n.readout b {\n  font-family: monospace;\n}\n.pill {\n  background: #eef2ff;\n  color: #4338ca;\n  border-radius: 999px;\n  padding: 3px 11px;\n  font-weight: 600;\n}\n.note {\n  background: #f5f8ff;\n  border-left: 3px solid #4f46e5;\n  padding: 11px 15px;\n  font-size: 13px;\n  color: #234;\n  border-radius: 2px;\n  line-height: 1.6;\n}\n.note code {\n  background: #e6ecff;\n  padding: 1px 5px;\n  border-radius: 3px;\n}\n.gestures {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));\n  gap: 10px;\n  margin: 4px 0 2px;\n}\n.gesture {\n  border: 1px solid #e2e6f0;\n  border-radius: 8px;\n  padding: 10px 13px;\n  font-family: sans-serif;\n}\n.gesture h4 {\n  margin: 0 0 3px;\n  font-size: 13px;\n  color: #4338ca;\n}\n.gesture p {\n  margin: 0;\n  font-size: 12.5px;\n  color: #445;\n  line-height: 1.5;\n}\n</style>\n"
    }
  ]
}