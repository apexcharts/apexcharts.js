{
  "title": "Crossfilter: Brush a Range to Filter (chart.link)",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"cf-wrap\">\n      <div class=\"cf-bar\">\n        <button id=\"cf-reset\">Reset</button>\n        <span class=\"readout\" id=\"cf-readout\"\n          >Drag a range on the histogram to filter the quarter chart</span\n        >\n      </div>\n\n      <div class=\"cf-card\">\n        <div id=\"chart\">\n          <apexchart\n            type=\"bar\"\n            height=\"260\"\n            :options=\"chartOptions\"\n            :series=\"series\"\n          ></apexchart>\n        </div>\n      </div>\n      <div class=\"cf-card\">\n        <div id=\"chart2\">\n          <apexchart\n            type=\"bar\"\n            height=\"240\"\n            :options=\"chartOptions1\"\n            :series=\"series1\"\n          ></apexchart>\n        </div>\n      </div>\n\n      <div class=\"cf-note\">\n        The top chart is a <b>histogram</b> of daily fluctuation %, binned by\n        the <code>link</code> engine (<code>bins: &#123; count &#125;</code>) on\n        a numeric x-axis. It has <code>chart.selection.enabled</code>, so\n        brushing a range sets a <code>[min, max]</code> filter on the\n        fluctuation dimension: the bottom chart <b>re-aggregates</b> to just the\n        days in that range, and the histogram dims the bins outside it. Because\n        a chart never filters itself, the histogram's own bars keep their full\n        shape. <b>Reset</b> clears the brush.\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\n// Deterministic daily market data: a fluctuation % and the quarter it fell in.\nfunction marketData() {\n  var quarters = ['Q1', 'Q2', 'Q3', 'Q4']\n  var out = []\n  for (var i = 0; i < 92; i++) {\n    var pct =\n      3.2 * Math.sin(i / 4.0) + 1.4 * Math.sin(i / 1.3) + 0.5 * Math.cos(i / 2.7)\n    out.push({\n      day: i,\n      pct: Math.round(pct * 100) / 100,\n      q: quarters[Math.floor(i / 23) % 4],\n    })\n  }\n  return out\n}\n\n// Register the shared records BEFORE the charts are constructed.\nApexCharts.crossfilter({ id: 'market', records: marketData() })\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [],\nchartOptions: {\nchart: {\n  id: 'fluctuation',\n  type: 'bar',\n  height: 260,\n  fontFamily: 'Helvetica, Arial, sans-serif',\n  animations: { speed: 450 },\n  zoom: { enabled: false },\n  selection: { enabled: true },\n  toolbar: {\n    autoSelected: 'selection',\n    tools: { selection: true, zoom: false, pan: false, reset: false, download: false },\n  },\n  link: {\n    id: 'market',\n    dimension: function (r) { return r.pct },\n    bins: { count: 24 },\n    dimOpacity: 0.16,\n  },\n},\ntitle: { text: 'Daily fluctuation % (brush a range here)', align: 'left' },\nplotOptions: { bar: { columnWidth: '92%' } },\ndataLabels: { enabled: false },\nxaxis: { type: 'numeric', tickAmount: 8, labels: { formatter: function (v) { return Number(v).toFixed(1) + '%' } } },\ncolors: ['#6366f1'],\n},\nseries1: [],\nchartOptions1: {\nchart: {\n  id: 'byQuarter',\n  type: 'bar',\n  height: 240,\n  fontFamily: 'Helvetica, Arial, sans-serif',\n  animations: { speed: 450 },\n  link: {\n    id: 'market',\n    dimension: function (r) { return r.q },\n    reduce: 'count',\n    seriesName: 'Days',\n  },\n},\ntitle: { text: 'Days by quarter (crossfiltered)', align: 'left' },\nplotOptions: { bar: { columnWidth: '55%', borderRadius: 3, distributed: true } },\nlegend: { show: false },\ndataLabels: { enabled: true },\ncolors: ['#6366f1', '#0ea5e9', '#22c55e', '#f59e0b'],\n},\ncfTimer: null,\n}\n},\nmounted: function () {\n  // The vue-apexcharts wrapper owns the render, and the crossfilter engine is\n  // registered by the shared head script (ApexCharts.crossfilter). Poll until the\n  // engine exists, then wire the readout + Reset button the same way the vanilla\n  // build does.\n  this.cfTimer = window.setInterval(function () {\n    var cf = ApexCharts.getCrossfilter('market')\n    if (!cf) return\n    window.clearInterval(this.cfTimer)\n\n    var readout = document.getElementById('cf-readout')\n    cf.on('change', function (state) {\n      var r = state.filters.fluctuation\n      if (r) {\n        readout.textContent =\n          'Fluctuation ' + r[0].toFixed(2) + '% to ' + r[1].toFixed(2) +\n          '%   ->   ' + state.filteredCount + ' / ' + state.total + ' days'\n      } else {\n        readout.textContent = 'No filter (all ' + state.total + ' days)'\n      }\n    })\n\n    document.getElementById('cf-reset').addEventListener('click', function () {\n      cf.reset()\n    })\n  }.bind(this), 50)\n},\nbeforeDestroy: function () {\n  window.clearInterval(this.cfTimer)\n},,\n}\n</script>\n\n<style>\n.cf-wrap {\n  max-width: 700px;\n  margin: 12px auto;\n  font-family: Helvetica, Arial, sans-serif;\n}\n.cf-bar {\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  flex-wrap: wrap;\n  margin: 4px 6px 12px;\n}\n.cf-bar button {\n  padding: 6px 13px;\n  cursor: pointer;\n  border: 1px solid #6366f1;\n  color: #4338ca;\n  background: #fff;\n  border-radius: 6px;\n  font-size: 13px;\n  font-weight: 600;\n}\n.cf-bar .readout {\n  font-family: monospace;\n  font-size: 13px;\n  color: #445;\n}\n.cf-card {\n  border: 1px solid #eef;\n  border-radius: 8px;\n  padding: 6px;\n  margin-bottom: 8px;\n}\n.cf-note {\n  background: #eef2ff;\n  border-left: 3px solid #6366f1;\n  padding: 11px 15px;\n  font-size: 13px;\n  color: #234;\n  border-radius: 2px;\n  line-height: 1.6;\n  margin: 12px 6px;\n}\n.cf-note code {\n  background: #dfe3ff;\n  padding: 1px 5px;\n  border-radius: 3px;\n}\n</style>\n"
    }
  ]
}