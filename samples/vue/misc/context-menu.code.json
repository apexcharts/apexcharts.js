{
  "title": "Context Menu: Right-Click Actions (chart.contextMenu)",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"cm-panel\">\n      <div class=\"cm-readout\" id=\"cm-readout\">\n        Right-click anywhere on the plot to open the actions menu.\n      </div>\n    </div>\n\n    <div id=\"chart\">\n      <apexchart\n        type=\"line\"\n        height=\"400\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n\n    <div class=\"cm-panel\">\n      <div class=\"cm-note\">\n        Right-click (or long-press) the plot to open an anchored actions menu.\n        Because each verb receives the clicked data point, it acts\n        <b>right there</b>, not chart-wide like a toolbar button:\n        <b>Add note here</b> drops an editable, draggable callout at the click\n        and opens its floating editor (type to rename; the card also offers\n        accent colors, bold, text size, marker size/shape and delete, via\n        <code>chart.ink</code>). <b>Annotate here</b> drops a dashed vertical\n        line at the clicked x, and <b>Mark this level</b> a dashed horizontal\n        line at the clicked y: always a line, never a rectangle, styled via\n        <code>contextMenu.line</code> (label text, dash pattern, color) and just\n        as draggable, restylable and undoable as the note. A line's editor card\n        has separate <b>Label</b> and <b>Line</b> color rows, so a white label\n        chip never blanks the stroke. Click any note or line later to reopen its\n        editor. <b>Measure from here</b> seeds the ruler at the click, then a\n        second click completes the measurement (<code>chart.measure</code>). The\n        <b>Copy value</b> entry below is a custom item wired via\n        <code>contextMenu.items[].onClick</code>. Arrow keys move, Enter\n        activates, Escape closes.\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\nfunction series() {\n  var out = []\n  var v = 2200\n  for (var i = 0; i < 60; i++) {\n    v += Math.sin(i / 4) * 55 + (i * 5) - 6\n    out.push([i, Math.round(v)])\n  }\n  return out\n}\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [\n  { name: 'Revenue', data: series() }\n],\nchartOptions: {\nchart: {\n  id: 'ctxmenu',\n  type: 'line',\n  height: 400,\n  fontFamily: 'Helvetica, Arial, sans-serif',\n  animations: { enabled: false },\n  toolbar: { show: false },\n  zoom: { enabled: true, type: 'x' },\n  contextMenu: {\n    enabled: true,\n    line: { text: 'Event', strokeDashArray: 5, color: '#7c3aed' },\n    items: [\n      'annotate',\n      'xline',\n      'yline',\n      'measure',\n      {\n        id: 'copyValue',\n        label: 'Copy value',\n        onClick: function (chart, ctx) {\n          var msg = 'x=' + Math.round(ctx.x) + ', y=' + Math.round(ctx.y)\n          var readout = document.getElementById('cm-readout')\n          if (readout) readout.textContent = 'Copied ' + msg\n          if (navigator.clipboard) navigator.clipboard.writeText(msg).catch(function () {})\n        },\n      },\n    ],\n  },\n  measure: { enabled: true },\n  ink: { enabled: true },\n},\nstroke: { width: 2, curve: 'smooth' },\ncolors: ['#2563eb'],\ndataLabels: { enabled: false },\ntitle: { text: 'Revenue (right-click to add notes or measure)', align: 'left' },\nxaxis: { type: 'numeric', title: { text: 'Session' } },\nyaxis: { title: { text: 'Revenue' }, decimalsInFloat: 0 },\n},\nctxTimer: null,\n}\n},\nmounted: function () {\n  // The vue-apexcharts wrapper owns the render, so reach the live instance by\n  // its chart.id, then wire the same readout events the vanilla build does.\n  // (The context menu, ink and measure config all live in the chart options.)\n  var me = this\n  me.ctxTimer = window.setInterval(function () {\n    var chart = ApexCharts.getChartByID('ctxmenu')\n    if (!chart) return\n    window.clearInterval(me.ctxTimer)\n\n    var readout = document.getElementById('cm-readout')\n    chart.addEventListener('measured', function (c, o) {\n      readout.textContent =\n        'Measured: dy=' + Number(o.dy).toFixed(0) +\n        ' (' + (o.percentChange >= 0 ? '+' : '') + Number(o.percentChange).toFixed(1) + '%)'\n    })\n    chart.addEventListener('annotationCreated', function (c, o) {\n      var kind = o && o.type === 'xaxis' ? 'Dashed line' : o && o.type === 'yaxis' ? 'Level line' : 'Note'\n      readout.textContent =\n        kind + ' added. Type to rename it; the floating card restyles or deletes it. Drag to move.'\n    })\n  }, 50)\n},\nbeforeDestroy: function () {\n  window.clearInterval(this.ctxTimer)\n},,\n}\n</script>\n\n<style>\n#chart {\n  max-width: 820px;\n  margin: 12px auto;\n}\n.cm-panel {\n  max-width: 820px;\n  margin: 12px auto;\n  font-family: Helvetica, Arial, sans-serif;\n}\n.cm-note {\n  background: #eef6ff;\n  border-left: 3px solid #2563eb;\n  padding: 11px 15px;\n  font-size: 13px;\n  color: #234;\n  border-radius: 2px;\n  line-height: 1.6;\n  margin: 12px 6px;\n}\n.cm-note code {\n  background: #dbeafe;\n  padding: 1px 5px;\n  border-radius: 3px;\n}\n.cm-readout {\n  font-family: monospace;\n  font-size: 13px;\n  color: #445;\n  margin: 6px 6px 0;\n}\n</style>\n"
    }
  ]
}