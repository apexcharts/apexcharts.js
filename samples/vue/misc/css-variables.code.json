{
  "title": "CSS Variables as Fill Colors",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"controls\">\n      <button class=\"btn-color\" data-palette=\"ocean\">Ocean</button>\n      <button class=\"btn-color\" data-palette=\"sunset\">Sunset</button>\n      <button class=\"btn-color\" data-palette=\"forest\">Forest</button>\n      <button class=\"btn-color\" data-palette=\"neon\">Neon</button>\n      <button class=\"btn-color\" data-palette=\"candy\">Candy</button>\n      <button class=\"btn-color\" data-palette=\"arctic\">Arctic</button>\n    </div>\n\n    <div class=\"info\">\n      This example uses <strong>CSS variables</strong> as chart colors. The SVG\n      fill uses <code>var(--chart-primary)</code> directly — no JavaScript color\n      resolution needed. Toggle the theme or change palettes to see the chart\n      react instantly via CSS.\n    </div>\n\n    <div id=\"chart\">\n      <apexchart\n        type=\"bar\"\n        height=\"380\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n    <div id=\"chart2\">\n      <apexchart\n        type=\"area\"\n        height=\"350\"\n        :options=\"chartOptions1\"\n        :series=\"series1\"\n      ></apexchart>\n    </div>\n    <div id=\"chart3\">\n      <apexchart\n        type=\"donut\"\n        height=\"350\"\n        :options=\"chartOptions2\"\n        :series=\"series2\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\n// The palette buttons only flip data-theme on the document root element; the SVG\n// fills are var(--chart-*), so all three charts recolor via CSS with no JS\n// color resolution and no chart re-render. Shared by the vanilla-js, React\n// and Vue builds.\nfunction setPalette(name) {\n  document.documentElement.setAttribute('data-theme', name)\n}\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [{\n  name: 'Series A',\n  data: [44, 55, 41, 67, 22, 43]\n}, {\n  name: 'Series B',\n  data: [13, 23, 20, 8, 13, 27]\n}, {\n  name: 'Series C',\n  data: [11, 17, 15, 15, 21, 14]\n}],\nchartOptions: {\nchart: {\n  id: 'cssVarBar',\n  type: 'bar',\n  height: 380,\n  stacked: true,\n},\ncolors: [\n  'var(--chart-primary)',\n  'var(--chart-secondary)',\n  'var(--chart-tertiary)',\n],\nfill: {\n  opacity: 0.85,\n},\nplotOptions: {\n  bar: {\n    borderRadius: 4,\n    borderRadiusApplication: 'end',\n    borderRadiusWhenStacked: 'last',\n    horizontal: false,\n    columnWidth: '55%',\n  },\n},\ndataLabels: {\n  enabled: false,\n},\nxaxis: {\n  categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],\n},\nlegend: {\n  position: 'top',\n},\n},\nseries1: [{\n  name: 'Series A',\n  data: [31, 40, 28, 51, 42, 109, 80]\n}, {\n  name: 'Series B',\n  data: [11, 32, 45, 32, 34, 52, 41]\n}, {\n  name: 'Series C',\n  data: [5, 18, 12, 26, 15, 31, 22]\n}],\nchartOptions1: {\nchart: { id: 'cssVarArea', type: 'area', height: 350 },\ncolors: [\n  'var(--chart-primary)',\n  'var(--chart-secondary)',\n  'var(--chart-tertiary)',\n],\nfill: { type: 'solid', opacity: 0.3 },\nstroke: { curve: 'smooth', width: 2 },\ndataLabels: { enabled: false },\nxaxis: { categories: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'] },\nlegend: { position: 'top' },\n},\nseries2: [44, 33, 23],\nchartOptions2: {\nchart: { id: 'cssVarDonut', type: 'donut', height: 350 },\ncolors: [\n  'var(--chart-primary)',\n  'var(--chart-secondary)',\n  'var(--chart-tertiary)',\n],\nlabels: ['Desktop', 'Tablet', 'Mobile'],\nfill: { opacity: 1 },\nlegend: { position: 'bottom' },\n},\n}\n},\nmounted: function () {\n  // The buttons live in the template, so they are in the DOM here. setPalette\n  // lives in the shared head script; only CSS drives the recolor, so no chart\n  // instance is needed.\n  var buttons = Array.prototype.slice.call(document.querySelectorAll('.btn-color'))\n  this._paletteCleanup = buttons.map(function (btn) {\n    var handler = function () {\n      setPalette(btn.getAttribute('data-palette'))\n    }\n    btn.addEventListener('click', handler)\n    return function () {\n      btn.removeEventListener('click', handler)\n    }\n  })\n},\nbeforeDestroy: function () {\n  if (this._paletteCleanup) {\n    this._paletteCleanup.forEach(function (off) {\n      off()\n    })\n  }\n},,\n}\n</script>\n\n<style>\n:root,\n[data-theme='default'] {\n  --chart-primary: #008ffb;\n  --chart-secondary: #00e396;\n  --chart-tertiary: #feb019;\n}\n\n[data-theme='ocean'] {\n  --chart-primary: #0077b6;\n  --chart-secondary: #00b4d8;\n  --chart-tertiary: #90e0ef;\n}\n\n[data-theme='sunset'] {\n  --chart-primary: #e63946;\n  --chart-secondary: #f4a261;\n  --chart-tertiary: #e9c46a;\n}\n\n[data-theme='forest'] {\n  --chart-primary: #2d6a4f;\n  --chart-secondary: #52b788;\n  --chart-tertiary: #95d5b2;\n}\n\n[data-theme='neon'] {\n  --chart-primary: #9b5de5;\n  --chart-secondary: #f15bb5;\n  --chart-tertiary: #00f5d4;\n}\n\n[data-theme='candy'] {\n  --chart-primary: #ff69b4;\n  --chart-secondary: #ff85cb;\n  --chart-tertiary: #ffc8dd;\n}\n\n[data-theme='arctic'] {\n  --chart-primary: #4cc9f0;\n  --chart-secondary: #4895ef;\n  --chart-tertiary: #4361ee;\n}\n\nbody {\n  transition: background-color 0.3s;\n}\n\n.controls {\n  max-width: 650px;\n  margin: 20px auto 0;\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  flex-wrap: wrap;\n}\n\n.controls button {\n  padding: 8px 16px;\n  border: none;\n  border-radius: 6px;\n  cursor: pointer;\n  font-size: 14px;\n  font-weight: 600;\n  transition: 0.2s;\n}\n\n.btn-theme {\n  background: #333;\n  color: #fff;\n}\n\n.btn-theme:hover {\n  background: #555;\n}\n\n.btn-color {\n  color: #fff;\n}\n\n.btn-color[data-palette='ocean'] {\n  background: #0077b6;\n}\n.btn-color[data-palette='sunset'] {\n  background: #e63946;\n}\n.btn-color[data-palette='forest'] {\n  background: #2d6a4f;\n}\n.btn-color[data-palette='neon'] {\n  background: #9b5de5;\n}\n.btn-color[data-palette='candy'] {\n  background: #ff69b4;\n}\n.btn-color[data-palette='arctic'] {\n  background: #4cc9f0;\n}\n\n.info {\n  max-width: 650px;\n  margin: 12px auto;\n  padding: 12px;\n  background: #f0f4ff;\n  border-radius: 6px;\n  font-size: 13px;\n  line-height: 1.5;\n}\n\n#chart,\n#chart2,\n#chart3 {\n  max-width: 650px;\n  margin: 35px auto;\n  padding-top: 20px;\n  padding-left: 10px;\n  background: #fff;\n  border: 1px solid #ddd;\n  box-shadow: 0 22px 35px -16px rgba(0, 0, 0, 0.1);\n}\n</style>\n"
    }
  ]
