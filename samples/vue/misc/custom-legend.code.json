{
  "title": "Custom Legend",
  "externals": [
    "https://cdn.jsdelivr.net/npm/pretty-checkbox@3.0/dist/pretty-checkbox.min.css"
  ],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart-wrap\">\n      <div id=\"chart\">\n        <apexchart\n          type=\"line\"\n          height=\"310\"\n          :options=\"chartOptions\"\n          :series=\"series\"\n        ></apexchart>\n      </div>\n\n      <div class=\"legend\">\n        <div class=\"pretty p-svg p-smooth\">\n          <input type=\"checkbox\" checked value=\"Series Column\" />\n          <div class=\"state p-primary\">\n            <svg class=\"svg svg-icon\" viewBox=\"0 0 20 20\">\n              <path\n                d=\"M7.629,14.566c0.125,0.125,0.291,0.188,0.456,0.188c0.164,0,0.329-0.062,0.456-0.188l8.219-8.221c0.252-0.252,0.252-0.659,0-0.911c-0.252-0.252-0.659-0.252-0.911,0l-7.764,7.763L4.152,9.267c-0.252-0.251-0.66-0.251-0.911,0c-0.252,0.252-0.252,0.66,0,0.911L7.629,14.566z\"\n              ></path>\n            </svg>\n            <label>Column</label>\n          </div>\n        </div>\n\n        <div class=\"pretty p-svg p-smooth\">\n          <input type=\"checkbox\" checked value=\"Series Area\" />\n          <div class=\"state p-success\">\n            <svg class=\"svg svg-icon\" viewBox=\"0 0 20 20\">\n              <path\n                d=\"M7.629,14.566c0.125,0.125,0.291,0.188,0.456,0.188c0.164,0,0.329-0.062,0.456-0.188l8.219-8.221c0.252-0.252,0.252-0.659,0-0.911c-0.252-0.252-0.659-0.252-0.911,0l-7.764,7.763L4.152,9.267c-0.252-0.251-0.66-0.251-0.911,0c-0.252,0.252-0.252,0.66,0,0.911L7.629,14.566z\"\n              ></path>\n            </svg>\n            <label>Area</label>\n          </div>\n        </div>\n\n        <div class=\"pretty p-svg p-smooth\">\n          <input type=\"checkbox\" value=\"Series Line\" />\n          <div class=\"state p-warning\">\n            <svg class=\"svg svg-icon\" viewBox=\"0 0 20 20\">\n              <path\n                d=\"M7.629,14.566c0.125,0.125,0.291,0.188,0.456,0.188c0.164,0,0.329-0.062,0.456-0.188l8.219-8.221c0.252-0.252,0.252-0.659,0-0.911c-0.252-0.252-0.659-0.252-0.911,0l-7.764,7.763L4.152,9.267c-0.252-0.251-0.66-0.251-0.911,0c-0.252,0.252-0.252,0.66,0,0.911L7.629,14.566z\"\n              ></path>\n            </svg>\n            <label>Line</label>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\n// This demo also loads: https://cdn.jsdelivr.net/npm/pretty-checkbox@3.0/dist/pretty-checkbox.min.css\n\n// Shared wiring for all three builds. The chart instance is reached by its\n// chart.id, so vanilla, React and Vue share one implementation. Returns a\n// cleanup function once the chart exists, or null while it is still rendering.\nfunction wireCustomLegend() {\n  var chart = ApexCharts.getChartByID('customLegend')\n  if (!chart) return null\n\n  var allLegends = document.querySelectorAll(\".legend input[type='checkbox']\")\n\n  // On load, hide any series whose checkbox starts unchecked.\n  for (var i = 0; i < allLegends.length; i++) {\n    if (!allLegends[i].checked) chart.toggleSeries(allLegends[i].value)\n  }\n\n  // toggleSeries accepts the series name to toggle; the value attribute holds it.\n  var handlers = []\n  allLegends.forEach(function (cb) {\n    var fn = function () {\n      chart.toggleSeries(cb.value)\n    }\n    cb.addEventListener('change', fn)\n    handlers.push({ cb: cb, fn: fn })\n  })\n\n  return function () {\n    handlers.forEach(function (h) {\n      h.cb.removeEventListener('change', h.fn)\n    })\n  }\n}\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [{\n  name: 'Series Column',\n  type: 'column',\n  data: [23, 11, 22, 27, 13, 22, 37, 21, 44, 22, 30]\n}, {\n  name: 'Series Area',\n  type: 'area',\n  data: [44, 55, 41, 67, 22, 43, 21, 41, 56, 27, 43]\n}, {\n  name: 'Series Line',\n  type: 'line',\n  data: [30, 25, 36, 30, 45, 35, 64, 52, 59, 36, 39]\n}],\nchartOptions: {\nchart: {\n  id: 'customLegend',\n  height: 310,\n  type: 'line',\n  stacked: false,\n},\nstroke: {\n  width: [0, 2, 5],\n  curve: 'smooth'\n},\nplotOptions: {\n  bar: {\n    columnWidth: '50%'\n  }\n},\nfill: {\n  opacity: [0.85,0.25,1],\n  gradient: {\n    inverseColors: false,\n    shade: 'light',\n    type: \"vertical\",\n    opacityFrom: 0.85,\n    opacityTo: 0.55,\n    stops: [0, 100, 100, 100]\n  }\n},\nlabels: ['01/01/2003', '02/01/2003','03/01/2003','04/01/2003','05/01/2003','06/01/2003','07/01/2003','08/01/2003','09/01/2003','10/01/2003','11/01/2003'],\nmarkers: {\n  size: 0\n},\nxaxis: {\n  type:'datetime'\n},\nyaxis: {\n  title: {\n    text: 'Points',\n  },\n  min: 0\n},\nlegend: {\n  show: false\n},\ntooltip: {\n  shared: true,\n  intersect: false,\n  y: {\n    formatter: function (y) {\n      if(typeof y !== \"undefined\") {\n        return  y.toFixed(0) + \" points\";\n      }\n      return y;\n    }\n  }\n}\n},\n}\n},\nmounted: function () {\n  // The vue-apexcharts wrapper owns the render, so reach the live instance by\n  // its chart.id. Poll until it exists, then wire the same checkbox legend the\n  // vanilla build does. (wireCustomLegend lives in the shared head script.)\n  var me = this\n  var timer = window.setInterval(function () {\n    me.legendCleanup = wireCustomLegend()\n    if (me.legendCleanup) window.clearInterval(timer)\n  }, 50)\n},\nbeforeDestroy: function () {\n  if (this.legendCleanup) this.legendCleanup()\n},,\n}\n</script>\n\n<style>\n#chart-wrap {\n  max-width: 650px;\n  position: relative;\n  margin: 35px auto;\n}\n\n#chart {\n  padding-bottom: 30px;\n  max-width: 650px;\n}\n\n.legend {\n  max-width: 650px;\n  left: 80px;\n  bottom: 20px;\n  position: absolute;\n  text-align: center;\n  margin: 0 auto;\n}\n\n/* The check icon fill/stroke used to live in an inline style attribute on each\n   path; a class keeps the html valid for the JSX (React) and Vue builds too. */\n.legend .svg-icon path {\n  stroke: #fff;\n  fill: #fff;\n}\n</style>\n"
    }
  ]
}