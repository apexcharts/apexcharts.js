{
  "title": "Cadence: Pluggable Easing (chart.animations.easing)",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"panel\">\n      <div class=\"controls\">\n        <span class=\"label\">Easing:</span>\n        <button data-ease=\"easeInOutSine\" class=\"active\">\n          easeInOutSine (default)\n        </button>\n        <button data-ease=\"linear\">linear</button>\n        <button data-ease=\"easeOutBack\">easeOutBack</button>\n        <button data-ease=\"bounce\">bounce (custom)</button>\n        <button data-ease=\"[0.34,1.56,0.64,1]\">cubic-bezier</button>\n        <button class=\"shuffle\" id=\"shuffle\">Shuffle data</button>\n      </div>\n    </div>\n\n    <div id=\"chart\">\n      <apexchart\n        type=\"bar\"\n        height=\"400\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n\n    <div class=\"panel\">\n      <div class=\"note\">\n        Pick an easing, then <b>Shuffle data</b> to watch the bars tween to\n        their new heights with that curve. Set it via\n        <code>chart.animations.easing</code>: a registered name\n        (<code>'easeOutBack'</code>), a cubic-bezier\n        <code>[0.34, 1.56, 0.64, 1]</code>, or a function. Register your own\n        with <code>ApexCharts.registerEasing('bounce', fn)</code>. The default,\n        <code>'easeInOutSine'</code>, is the historical curve, so existing\n        charts animate exactly as before. Easing governs the data-update tweens\n        whose tempo is <code>dynamicAnimation.speed</code> (set to 900ms here so\n        the curve reads clearly); the tuned initial-draw pen and pop animations\n        keep their own feel.\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\n// Cadence: a custom named easing, registered before the chart is created.\n// A springy overshoot-and-settle bounce.\nApexCharts.registerEasing('bounce', function (t) {\n  var c4 = (2 * Math.PI) / 3\n  if (t === 0 || t === 1) return t\n  return Math.pow(2, -10 * t) * Math.sin((t * 10 - 0.75) * c4) + 1\n})\n\nfunction shuffledData() {\n  var out = []\n  for (var i = 0; i < 8; i++) out.push(20 + Math.round(Math.random() * 80))\n  return out\n}\n\n// A bracketed value is a cubic-bezier array; otherwise a registered name.\n// Shared by the vanilla-js, React and Vue builds.\nfunction parseEase(raw) {\n  if (raw.charAt(0) === '[') {\n    try { return JSON.parse(raw) } catch (e) { return raw }\n  }\n  return raw\n}\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [\n  { name: 'Value', data: [42, 68, 35, 80, 55, 24, 71, 60] }\n],\nchartOptions: {\nchart: {\n  id: 'cadenceChart',\n  height: 400,\n  type: 'bar',\n  fontFamily: 'Helvetica, Arial, sans-serif',\n  toolbar: { show: false },\n  animations: {\n    enabled: true,\n    speed: 900,\n    easing: 'easeInOutSine',\n    // The Shuffle button changes data, so the tween you watch is the\n    // data-update (dynamicAnimation) one. Slow it down so the easing curve is\n    // easy to read; chart.animations.speed above governs the initial draw.\n    dynamicAnimation: {\n      enabled: true,\n      speed: 900\n    },\n    animateGradually: {\n      enabled: false\n    }\n  },\n},\ncolors: ['#14b8a6'],\nplotOptions: { bar: { columnWidth: '55%', borderRadius: 4 } },\ndataLabels: { enabled: false },\ntitle: { text: 'Data-update tween easing', align: 'left' },\nxaxis: {\n  categories: ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H'],\n},\nyaxis: { min: 0, max: 100 },\n},\ncadenceTimer: null,\n}\n},\nmounted: function () {\n  // The vue-apexcharts wrapper owns the render, so reach the live instance by\n  // its chart.id, then wire the same controls the vanilla build does.\n  // (parseEase and shuffledData live in the shared head script.) updateOptions /\n  // updateSeries drive the chart instance directly, so no reactive data changes.\n  var me = this\n  me.cadenceTimer = window.setInterval(function () {\n    var chart = ApexCharts.getChartByID('cadenceChart')\n    if (!chart) return\n    window.clearInterval(me.cadenceTimer)\n\n    var buttons = Array.prototype.slice.call(\n      document.querySelectorAll('.controls button[data-ease]')\n    )\n    buttons.forEach(function (btn) {\n      btn.addEventListener('click', function () {\n        buttons.forEach(function (b) { b.classList.remove('active') })\n        btn.classList.add('active')\n        var currentEasing = parseEase(btn.getAttribute('data-ease'))\n        chart.updateOptions({ chart: { animations: { easing: currentEasing } } })\n      })\n    })\n\n    document.getElementById('shuffle').addEventListener('click', function () {\n      chart.updateSeries([{ name: 'Value', data: shuffledData() }])\n    })\n  }, 50)\n},\nbeforeDestroy: function () {\n  window.clearInterval(this.cadenceTimer)\n},,\n}\n</script>\n\n<style>\n#chart {\n  max-width: 820px;\n  margin: 12px auto 4px;\n}\n.panel {\n  max-width: 820px;\n  margin: 14px auto;\n  font-family: sans-serif;\n}\n.controls {\n  display: flex;\n  gap: 8px;\n  align-items: center;\n  flex-wrap: wrap;\n  margin-bottom: 6px;\n}\n.controls .label {\n  font-size: 13px;\n  color: #556;\n  margin-right: 2px;\n}\n.controls button {\n  padding: 6px 12px;\n  cursor: pointer;\n  border: 1px solid #d3d8e3;\n  background: #fff;\n  border-radius: 6px;\n  font-size: 13px;\n}\n.controls button.active {\n  border-color: #14b8a6;\n  color: #0f766e;\n  background: #f0fdfa;\n  font-weight: 600;\n}\n.controls .shuffle {\n  margin-left: auto;\n  border-color: #14b8a6;\n  color: #0f766e;\n  font-weight: 600;\n}\n.note {\n  background: #f0fdfa;\n  border-left: 3px solid #14b8a6;\n  padding: 11px 15px;\n  font-size: 13px;\n  color: #234;\n  border-radius: 2px;\n  line-height: 1.6;\n}\n.note code {\n  background: #c7f0ea;\n  padding: 1px 5px;\n  border-radius: 3px;\n}\n</style>\n"
    }
  ]
}