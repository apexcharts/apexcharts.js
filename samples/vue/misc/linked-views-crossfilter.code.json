{
  "title": "Linked Views: Crossfilter by Brushing (chart.link)",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"panel\">\n      <div class=\"bar\">\n        <button id=\"clear\">Clear crossfilter</button>\n        <span class=\"readout\" id=\"readout\"\n          >Drag a date range on the top chart to crossfilter both</span\n        >\n      </div>\n    </div>\n\n    <div class=\"wrap\">\n      <div id=\"chart\">\n        <apexchart\n          type=\"bar\"\n          height=\"250\"\n          :options=\"chartOptions\"\n          :series=\"series\"\n        ></apexchart>\n      </div>\n    </div>\n    <div class=\"wrap\">\n      <div id=\"chart2\">\n        <apexchart\n          type=\"scatter\"\n          height=\"250\"\n          :options=\"chartOptions1\"\n          :series=\"series1\"\n        ></apexchart>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <div class=\"note\">\n        Both charts share <code>chart.group: 'sales'</code> and opt in with\n        <code>chart.link.enabled</code>. The top chart also has\n        <code>chart.selection.enabled</code>, so dragging a date range on it\n        dims every data point (in both charts) whose date falls outside the\n        range, in place, with no re-render and no axis change. Slide or resize\n        the selection box (or draw a new one) to update the filter live;\n        <b>Clear crossfilter</b> (or <code>chart.clearCrossfilter()</code>)\n        restores. Needs the <code>link</code> feature. Highlight mode works on\n        discrete marks (columns, scatter); a continuous line path is not dimmed\n        per segment.\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\n// Deterministic 30-day dashboard data (no randomness, stable demo).\nvar LV_START = new Date('2024-03-01').getTime()\nvar LV_DAY = 86400000\nfunction ordersData() {\n  var out = []\n  for (var i = 0; i < 30; i++) {\n    var v = 60 + 30 * Math.sin(i / 3.3) + 14 * Math.sin(i / 1.7) + i * 0.6\n    out.push([LV_START + i * LV_DAY, Math.round(v)])\n  }\n  return out\n}\nfunction valueData() {\n  var out = []\n  for (var i = 0; i < 30; i++) {\n    // average order value, loosely anti-correlated with volume\n    var v = 120 - 22 * Math.sin(i / 3.3) + 10 * Math.cos(i / 2.1)\n    out.push([LV_START + i * LV_DAY, Math.round(v)])\n  }\n  return out\n}\n\n// Shared by the vanilla-js, React and Vue builds.\nfunction fmt(ts) { return new Date(ts).toISOString().slice(0, 10) }\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [\n  { name: 'Orders', data: ordersData() }\n],\nchartOptions: {\nchart: {\n  id: 'orders',\n  height: 250,\n  type: 'bar',\n  group: 'sales',\n  fontFamily: 'Helvetica, Arial, sans-serif',\n  animations: { enabled: false },\n  link: { enabled: true, dimOpacity: 0.16 },\n  selection: { enabled: true },\n  toolbar: { autoSelected: 'selection', tools: { selection: true, zoom: false, pan: false, reset: false, download: false } },\n},\ncolors: ['#6366f1'],\nplotOptions: { bar: { columnWidth: '60%', borderRadius: 2 } },\ndataLabels: { enabled: false },\ntitle: { text: 'Daily orders (brush a range here)', align: 'left' },\nxaxis: { type: 'datetime' },\n},\nseries1: [\n  { name: 'Avg value', data: valueData() }\n],\nchartOptions1: {\nchart: {\n  id: 'value',\n  height: 250,\n  type: 'scatter',\n  group: 'sales',\n  fontFamily: 'Helvetica, Arial, sans-serif',\n  animations: { enabled: false },\n  link: { enabled: true, dimOpacity: 0.16 },\n  zoom: { enabled: false },\n  toolbar: { show: false },\n},\ncolors: ['#0ea5e9'],\nmarkers: { size: 6 },\ntitle: { text: 'Avg order value (crossfiltered)', align: 'left' },\nxaxis: { type: 'datetime' },\nyaxis: { labels: { formatter: function (v) { return '$' + Math.round(v) } } },\n},\n}\n},\nmounted: function () {\n  // The vue-apexcharts wrapper owns the render, so reach the brush-source chart\n  // ('orders') by its chart.id. Poll until it exists, then wire the same\n  // crossfilter readout + clear button the vanilla build does. (fmt lives in the\n  // shared head script.) The link feature drives the chart instances directly,\n  // so no reactive data changes and the charts are not re-rendered under it.\n  var me = this\n  var readout = document.getElementById('readout')\n  me._onClear = function () {\n    if (me._chart) me._chart.clearCrossfilter()\n    if (readout) readout.textContent = 'Cleared'\n  }\n  var timer = window.setInterval(function () {\n    var chart = ApexCharts.getChartByID('orders')\n    if (!chart) return\n    window.clearInterval(timer)\n    me._timer = null\n    me._chart = chart\n    chart.addEventListener('crossFilter', function (c, opts) {\n      readout.textContent = 'Filtered: ' + fmt(opts.xaxis.min) + ' to ' + fmt(opts.xaxis.max)\n    })\n    document.getElementById('clear').addEventListener('click', me._onClear)\n  }, 50)\n  me._timer = timer\n},\nbeforeDestroy: function () {\n  if (this._timer) window.clearInterval(this._timer)\n  var btn = document.getElementById('clear')\n  if (btn && this._onClear) btn.removeEventListener('click', this._onClear)\n},,\n}\n</script>\n\n<style>\n.wrap {\n  max-width: 820px;\n  margin: 12px auto;\n}\n.panel {\n  max-width: 820px;\n  margin: 12px auto;\n  font-family: sans-serif;\n}\n.bar {\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  flex-wrap: wrap;\n  margin-bottom: 4px;\n}\n.bar button {\n  padding: 6px 13px;\n  cursor: pointer;\n  border: 1px solid #6366f1;\n  color: #4338ca;\n  background: #fff;\n  border-radius: 6px;\n  font-size: 13px;\n  font-weight: 600;\n}\n.bar .readout {\n  font-family: monospace;\n  font-size: 13px;\n  color: #445;\n}\n.note {\n  background: #eef2ff;\n  border-left: 3px solid #6366f1;\n  padding: 11px 15px;\n  font-size: 13px;\n  color: #234;\n  border-radius: 2px;\n  line-height: 1.6;\n}\n.note code {\n  background: #dfe3ff;\n  padding: 1px 5px;\n  border-radius: 3px;\n}\n</style>\n"
    }
  ]
}