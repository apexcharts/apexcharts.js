{
  "title": "Registered Brand Themes (Facet)",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"panel\">\n      <div class=\"controls\">\n        <label>\n          Theme:\n          <select id=\"themePick\">\n            <option value=\"sunset\" selected>sunset</option>\n            <option value=\"ocean\">ocean</option>\n            <option value=\"slate\">slate (dark)</option>\n          </select>\n        </label>\n      </div>\n    </div>\n\n    <div id=\"chart\">\n      <apexchart\n        type=\"bar\"\n        height=\"400\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n\n    <div class=\"panel\">\n      <div class=\"note\">\n        Three themes are registered once with\n        <code\n          >ApexCharts.registerTheme(name, &#123; palette, tokens, mode\n          &#125;)</code\n        >. The chart references one via\n        <code>theme: &#123; name: 'sunset' &#125;</code> and the dropdown\n        switches with\n        <code>chart.updateOptions(&#123; theme: &#123; name &#125; &#125;)</code\n        >. A registered theme sits below explicit config and CSS\n        <code>--apx-*</code>\n        tokens, so a page-level token can still override a brand default.\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\n// Facet (#13): register named themes ONCE (palette + design tokens + mode).\n// Any chart can then reference one by name via theme:{ name }, and switching\n// themes is a single updateOptions call.\nApexCharts.registerTheme('sunset', {\n  palette: ['#ff6b6b', '#f06595', '#cc5de8', '#845ef7', '#ff922b'],\n  tokens: { fore: '#5c3d2e', grid: '#f3d9c4', surface: '#fff8f2' },\n})\nApexCharts.registerTheme('ocean', {\n  palette: ['#0ca678', '#1098ad', '#1971c2', '#3b5bdb', '#0b7285'],\n  tokens: { fore: '#0b3d4d', grid: '#c5e4ec', surface: '#f2fbfd' },\n})\nApexCharts.registerTheme('slate', {\n  mode: 'dark',\n  palette: ['#94a3b8', '#38bdf8', '#a78bfa', '#f472b6', '#fbbf24'],\n  tokens: { fore: '#e2e8f0', grid: '#334155', surface: '#0f172a' },\n})\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [\n  { name: 'Revenue', data: [44, 62, 51, 38, 47] }\n],\nchartOptions: {\nchart: {\n  id: 'facetBrandChart',\n  height: 400,\n  type: 'bar',\n  fontFamily: 'sans-serif',\n  animations: { enabled: true },\n  toolbar: { show: false },\n},\ntheme: {\n  name: 'sunset',\n},\nplotOptions: { bar: { columnWidth: '55%', borderRadius: 4, distributed: true } },\ndataLabels: { enabled: false },\nlegend: { show: false },\ntitle: {\n  text: 'Revenue by channel',\n  align: 'left',\n},\nsubtitle: {\n  text: 'Palette and chrome come from a registered brand theme',\n  align: 'left',\n},\nxaxis: {\n  type: 'category',\n  categories: ['Direct', 'Search', 'Social', 'Email', 'Referral'],\n},\n},\n}\n},\nmounted: function () {\n  // The vue-apexcharts wrapper owns the render, so reach the live instance by\n  // its chart.id at event time.\n  var pick = document.getElementById('themePick')\n  var onChange = function (e) {\n    var chart = ApexCharts.getChartByID('facetBrandChart')\n    if (chart) chart.updateOptions({ theme: { name: e.target.value } })\n  }\n  pick.addEventListener('change', onChange)\n  this._onThemeChange = onChange\n  this._themePick = pick\n},\nbeforeDestroy: function () {\n  if (this._themePick) {\n    this._themePick.removeEventListener('change', this._onThemeChange)\n  }\n},,\n}\n</script>\n\n<style>\n#chart {\n  max-width: 720px;\n  margin: 16px auto;\n}\n.panel {\n  max-width: 720px;\n  margin: 16px auto;\n  font-family: sans-serif;\n}\n.controls {\n  display: flex;\n  gap: 12px;\n  align-items: center;\n  margin-bottom: 8px;\n}\n.controls select {\n  padding: 5px 8px;\n  font-size: 14px;\n}\n.note {\n  background: #f6f6fb;\n  border-left: 3px solid #6c5ce7;\n  padding: 10px 14px;\n  font-size: 13px;\n  color: #234;\n  border-radius: 2px;\n  line-height: 1.55;\n}\n.note code {\n  background: #e9e7fb;\n  padding: 1px 5px;\n  border-radius: 3px;\n}\n</style>\n"
    }
  ]
}