{
  "title": "Dynamic Data: Smooth Add / Remove / Insert Transitions",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div class=\"dt-wrap\">\n      <div class=\"dt-bar\">\n        <button id=\"dt-add\">+ Add month</button>\n        <button id=\"dt-insert\">Insert middle</button>\n        <button id=\"dt-remove-last\">Remove last</button>\n        <button id=\"dt-remove-mid\">Remove middle</button>\n        <button id=\"dt-rotate\">Rotate values</button>\n        <button id=\"dt-reset\">Reset</button>\n        <label><input type=\"checkbox\" id=\"dt-slow\" /> Slow motion</label>\n      </div>\n\n      <div class=\"dt-card\">\n        <div id=\"chart\">\n          <apexchart\n            type=\"bar\"\n            height=\"280\"\n            :options=\"chartOptions\"\n            :series=\"series\"\n          ></apexchart>\n        </div>\n      </div>\n      <div class=\"dt-card\">\n        <div id=\"chart2\">\n          <apexchart\n            type=\"area\"\n            height=\"280\"\n            :options=\"chartOptions1\"\n            :series=\"series1\"\n          ></apexchart>\n        </div>\n      </div>\n\n      <div class=\"dt-note\">\n        Every button changes the NUMBER of data points, not just their values.\n        Entering columns grow from the baseline of their final slot while the\n        survivors slide over on one clock; a removed column shrinks out as a\n        fading ghost; inserting in the middle keeps each datum's identity (bars\n        are matched by category, so existing columns slide instead of morphing\n        into their neighbor's value). On the area chart the fill stays intact\n        mid-transition, markers ride the moving line, and the axis labels travel\n        with their columns. All of this is default behavior of\n        <code>updateOptions()</code> / <code>updateSeries()</code>: no extra\n        config. <b>Rotate values</b> is the same-length control case, which\n        keeps the classic value morph.\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\nimport ApexCharts from 'apexcharts'\n\n// State + data helpers shared by the vanilla-js, React and Vue builds. Both\n// charts are driven directly through their chart.id, so the wiring is one\n// implementation for all three formats.\nvar MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']\nvar INITIAL = { labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'], values: [42, 61, 45, 78, 52, 89, 66] }\n\nvar state = {\n  labels: INITIAL.labels.slice(),\n  values: INITIAL.values.slice(),\n  monthCursor: INITIAL.labels.length, // next month to append\n  insertCount: 0,\n}\n\n// Deterministic \"random\" value so the demo replays identically.\nfunction nextValue(seed) {\n  return 30 + ((seed * 37) % 60)\n}\n\nfunction monthLabel(i) {\n  var name = MONTHS[i % 12]\n  return i > 11 ? name + \" '26\" : name\n}\n\nfunction speed() {\n  return document.getElementById('dt-slow').checked ? 1800 : 650\n}\n\nfunction pushState() {\n  var barChart = ApexCharts.getChartByID('dtBar')\n  var areaChart = ApexCharts.getChartByID('dtArea')\n  if (!barChart || !areaChart) return\n\n  var payload = {\n    chart: { animations: { dynamicAnimation: { speed: speed() } } },\n    xaxis: { categories: state.labels.slice() },\n  }\n  barChart.updateOptions(\n    Object.assign({ series: [{ name: 'Revenue', data: state.values.slice() }] }, payload),\n    false,\n    true\n  )\n  areaChart.updateOptions(\n    Object.assign(\n      {\n        series: [\n          {\n            name: 'Users',\n            data: state.values.map(function (v) {\n              return Math.round(v * 0.6 + 10)\n            }),\n          },\n        ],\n      },\n      payload\n    ),\n    false,\n    true\n  )\n  syncButtons()\n}\n\nfunction syncButtons() {\n  document.getElementById('dt-add').disabled = state.labels.length >= 20\n  document.getElementById('dt-insert').disabled = state.labels.length >= 20\n  document.getElementById('dt-remove-last').disabled = state.labels.length <= 3\n  document.getElementById('dt-remove-mid').disabled = state.labels.length <= 3\n}\n\n// Attach every button, then set the initial disabled state. Returns a cleanup\n// function that detaches the listeners (used by the React/Vue teardown).\nfunction wireDynamicData() {\n  var handlers = []\n  function on(id, fn) {\n    var el = document.getElementById(id)\n    if (!el) return\n    el.addEventListener('click', fn)\n    handlers.push({ el: el, fn: fn })\n  }\n\n  on('dt-add', function () {\n    state.labels.push(monthLabel(state.monthCursor))\n    state.values.push(nextValue(state.monthCursor))\n    state.monthCursor++\n    pushState()\n  })\n\n  on('dt-insert', function () {\n    var at = Math.floor(state.labels.length / 2)\n    state.insertCount++\n    state.labels.splice(at, 0, 'New ' + state.insertCount)\n    state.values.splice(at, 0, nextValue(state.insertCount * 5 + 3))\n    pushState()\n  })\n\n  on('dt-remove-last', function () {\n    state.labels.pop()\n    state.values.pop()\n    pushState()\n  })\n\n  on('dt-remove-mid', function () {\n    var at = Math.floor(state.labels.length / 2)\n    state.labels.splice(at, 1)\n    state.values.splice(at, 1)\n    pushState()\n  })\n\n  on('dt-rotate', function () {\n    state.values.push(state.values.shift())\n    pushState()\n  })\n\n  on('dt-reset', function () {\n    state.labels = INITIAL.labels.slice()\n    state.values = INITIAL.values.slice()\n    state.monthCursor = INITIAL.labels.length\n    state.insertCount = 0\n    pushState()\n  })\n\n  syncButtons()\n\n  return function () {\n    handlers.forEach(function (h) {\n      h.el.removeEventListener('click', h.fn)\n    })\n  }\n}\n\nexport default {\ncomponents: {\napexchart: VueApexCharts,\n},\ndata: function () {\nreturn {\nseries: [{\n  name: 'Revenue',\n  data: [42, 61, 45, 78, 52, 89, 66]\n}],\nchartOptions: {\nchart: {\n  id: 'dtBar',\n  type: 'bar',\n  height: 280,\n  fontFamily: 'Helvetica, Arial, sans-serif',\n  toolbar: { show: false },\n  zoom: { enabled: false },\n  animations: { speed: 700, dynamicAnimation: { speed: 650 } },\n},\ntitle: { text: 'Monthly revenue (k$)', align: 'left' },\ncolors: ['#6366f1'],\nplotOptions: { bar: { columnWidth: '60%', borderRadius: 2 } },\ndataLabels: { enabled: false },\nxaxis: { categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'] },\nyaxis: { min: 0, max: 100, tickAmount: 4 },\ngrid: { padding: { top: -10 } }\n},\nseries1: [{\n  name: 'Users',\n  data: [35, 47, 37, 57, 41, 63, 50]\n}],\nchartOptions1: {\nchart: {\n  id: 'dtArea',\n  type: 'area',\n  height: 280,\n  fontFamily: 'Helvetica, Arial, sans-serif',\n  toolbar: { show: false },\n  zoom: { enabled: false },\n  animations: { speed: 700, dynamicAnimation: { speed: 650 } },\n},\ntitle: { text: 'Active users (k)', align: 'left' },\ncolors: ['#0ea5e9'],\nstroke: { curve: 'smooth', width: 3 },\nfill: { type: 'gradient', gradient: { opacityFrom: 0.45, opacityTo: 0.05 } },\nmarkers: { size: 4 },\ndataLabels: { enabled: true, offsetY: -6 },\nxaxis: { categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'] },\nyaxis: { min: 0, max: 70, tickAmount: 4 },\ngrid: { padding: { top: -10 } }\n},\n}\n},\nmounted: function () {\n  // The vue-apexcharts wrapper owns the render, so reach the live instances by\n  // their chart.id. Poll until BOTH exist, then wire the same buttons the\n  // vanilla build does. (State + helpers live in the shared head script.) The\n  // buttons drive the chart instances directly, so no reactive data changes and\n  // the <apexchart> tags are never re-rendered under them.\n  var me = this\n  var timer = window.setInterval(function () {\n    var bar = ApexCharts.getChartByID('dtBar')\n    var area = ApexCharts.getChartByID('dtArea')\n    if (!bar || !area) return\n    window.clearInterval(timer)\n    me.dtCleanup = wireDynamicData()\n  }, 50)\n},\nbeforeDestroy: function () {\n  if (this.dtCleanup) this.dtCleanup()\n},,\n}\n</script>\n\n<style>\n.dt-wrap {\n  max-width: 780px;\n  margin: 14px auto;\n  font-family: Helvetica, Arial, sans-serif;\n}\n.dt-bar {\n  display: flex;\n  gap: 8px;\n  align-items: center;\n  flex-wrap: wrap;\n  margin: 4px 6px 14px;\n}\n.dt-bar button {\n  padding: 6px 13px;\n  cursor: pointer;\n  border: 1px solid #6366f1;\n  color: #4338ca;\n  background: #fff;\n  border-radius: 6px;\n  font-size: 13px;\n  font-weight: 600;\n}\n.dt-bar button:disabled {\n  opacity: 0.45;\n  cursor: default;\n}\n.dt-bar label {\n  font-size: 13px;\n  color: #445;\n  margin-left: 6px;\n  user-select: none;\n}\n.dt-card {\n  border: 1px solid #e4e7f2;\n  border-radius: 8px;\n  padding: 6px;\n  background: #fff;\n  margin-bottom: 10px;\n}\n/* The shared demo stylesheet gives the FIRST chart container (#chart) a\n     white panel + border; the cards style both charts uniformly instead. */\n#chart {\n  padding: 0;\n  background: transparent;\n  border: 0;\n  box-shadow: none;\n}\n.dt-note {\n  background: #eef2ff;\n  border-left: 3px solid #6366f1;\n  padding: 11px 15px;\n  font-size: 13px;\n  color: #234;\n  border-radius: 2px;\n  line-height: 1.6;\n  margin: 14px 6px;\n}\n.dt-note code {\n  background: #dfe3ff;\n  padding: 1px 5px;\n  border-radius: 3px;\n}\n</style>\n"
    }
  ]
}