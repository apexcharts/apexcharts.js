{
  "title": "Line with different negative color",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"line\"\n        height=\"350\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Temperature Anomaly',\n          data: [\n            -1.4, 2.6, -0.8, 3.4, -2.1, 1.9, 4.2, -1.6, 2.8, -3.2, 1.2, 3.9,\n          ],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          height: 350,\n          type: 'line',\n          zoom: {\n            enabled: false,\n          },\n        },\n        dataLabels: {\n          enabled: false,\n        },\n        title: {\n          text: 'Monthly Temperature Anomaly',\n          align: 'left',\n        },\n        subtitle: {\n          text: 'Months below the baseline draw in a different color',\n          align: 'left',\n        },\n        yaxis: {\n          labels: {\n            formatter: function (val) {\n              return val.toFixed(1) + '°C'\n            },\n          },\n        },\n        xaxis: {\n          categories: [\n            'Jan',\n            'Feb',\n            'Mar',\n            'Apr',\n            'May',\n            'Jun',\n            'Jul',\n            'Aug',\n            'Sep',\n            'Oct',\n            'Nov',\n            'Dec',\n          ],\n        },\n        stroke: {\n          width: 5,\n          curve: 'monotoneCubic',\n        },\n        plotOptions: {\n          line: {\n            colors: {\n              threshold: 0,\n              colorAboveThreshold: '#008FFB',\n              colorBelowThreshold: '#FF4560',\n            },\n          },\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
}