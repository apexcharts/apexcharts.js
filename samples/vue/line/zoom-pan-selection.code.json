{
  "title": "Zoom Pan Selection",
  "externals": [],
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"line\"\n        height=\"400\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\n// Deterministic minute-by-minute throughput with a traffic burst around x=38,\n// so there is something worth zooming into.\nfunction mulberry32(seed) {\n  return function () {\n    seed |= 0\n    seed = (seed + 0x6d2b79f5) | 0\n    var t = Math.imul(seed ^ (seed >>> 15), 1 | seed)\n    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t\n    return ((t ^ (t >>> 14)) >>> 0) / 4294967296\n  }\n}\n\nvar rand = mulberry32(7)\nvar trafficData = []\nvar level = 40\nfor (var i = 1; i <= 60; i++) {\n  level += (rand() - 0.5) * 12\n  if (level < 15) level = 15\n  var y = level\n  if (i >= 32 && i <= 44) {\n    y += 70 * Math.exp(-Math.pow(i - 38, 2) / 8)\n  }\n  trafficData.push([i, Math.round(y)])\n}\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Throughput',\n          data: trafficData,\n        },\n      ],\n      chartOptions: {\n        chart: {\n          type: 'line',\n          height: 400,\n          zoom: {\n            enabled: true,\n            type: 'x',\n            autoScaleYaxis: false,\n          },\n          toolbar: {\n            autoSelected: 'zoom',\n          },\n          animations: { enabled: false },\n        },\n        title: {\n          text: 'Network Throughput (Mbps)',\n          align: 'left',\n        },\n        subtitle: {\n          text: 'Drag to zoom into the traffic burst around minute 38',\n          align: 'left',\n        },\n        dataLabels: { enabled: false },\n        markers: { size: 0 },\n        xaxis: {\n          type: 'numeric',\n          title: {\n            text: 'Minute',\n          },\n        },\n        yaxis: { min: 0 },\n        stroke: { curve: 'monotoneCubic' },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 700px;\n  margin: 30px auto;\n}\n</style>\n"
    }
  ]
