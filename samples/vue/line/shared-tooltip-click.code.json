{
  "title": "Line: Shared Tooltip Click Reports Correct Series",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"line\"\n        height=\"380\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        { name: 'Desktops', data: [10, 16, 12, 18, 13, 20, 15, 22, 17] },\n        { name: 'Tablets', data: [38, 45, 40, 47, 42, 49, 44, 51, 46] },\n        { name: 'Phones', data: [66, 73, 68, 75, 70, 77, 72, 79, 74] },\n        { name: 'Watches', data: [94, 101, 96, 103, 98, 105, 100, 107, 102] },\n        {\n          name: 'Projectors',\n          data: [122, 129, 124, 131, 126, 133, 128, 135, 130],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          height: 380,\n          width: '100%',\n          type: 'line',\n        },\n        tooltip: {\n          shared: true,\n        },\n        markers: {\n          size: 5,\n        },\n        stroke: {\n          curve: 'straight',\n        },\n        title: {\n          text: 'Shared tooltip: click reports the clicked series',\n          align: 'left',\n        },\n        xaxis: {\n          categories: [\n            'Jan',\n            'Feb',\n            'Mar',\n            'Apr',\n            'May',\n            'Jun',\n            'Jul',\n            'Aug',\n            'Sep',\n          ],\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
}