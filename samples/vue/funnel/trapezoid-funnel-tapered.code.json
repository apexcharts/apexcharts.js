{
  "title": "Trapezoid Funnel — Tapered",
  "files": [
    {
      "name": "App.vue",
      "language": "xml",
      "code": "<template>\n  <div>\n    <div id=\"chart\">\n      <apexchart\n        type=\"funnel\"\n        height=\"420\"\n        :options=\"chartOptions\"\n        :series=\"series\"\n      ></apexchart>\n    </div>\n  </div>\n</template>\n\n<script>\nimport VueApexCharts from 'vue-apexcharts'\n\nexport default {\n  components: {\n    apexchart: VueApexCharts,\n  },\n  data: function () {\n    return {\n      series: [\n        {\n          name: 'Subscribers',\n          data: [1200, 480, 160, 32],\n        },\n      ],\n      chartOptions: {\n        chart: {\n          type: 'funnel',\n          height: 420,\n        },\n        plotOptions: {\n          funnel: {\n            shape: 'trapezoid',\n            lastShape: 'taper',\n          },\n          bar: {\n            barHeight: '90%',\n            distributed: true,\n          },\n        },\n        colors: ['#10B981', '#34D399', '#6EE7B7', '#A7F3D0'],\n        dataLabels: {\n          enabled: true,\n          formatter: function (val, opt) {\n            return opt.w.globals.labels[opt.dataPointIndex] + ': ' + val\n          },\n          style: {\n            colors: ['#064E3B'],\n            fontSize: '13px',\n            fontWeight: 600,\n          },\n        },\n        title: {\n          text: 'Newsletter Funnel — Tapered',\n          align: 'middle',\n        },\n        xaxis: {\n          categories: ['Delivered', 'Opened', 'Clicked', 'Converted'],\n        },\n        legend: {\n          show: false,\n        },\n      },\n    }\n  },\n}\n</script>\n\n<style>\n#chart {\n  max-width: 650px;\n  margin: 35px auto;\n}\n</style>\n"
    }
  ]
}